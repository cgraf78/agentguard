#!/usr/bin/env bash
# agent-hook-session-start — SessionStart hook.
# Reports repo state, disk pressure, and startup Hive Memory context.

set -u
_HOOK_SELF="${AGENTGUARD_HOOK_SELF:-$0}" # captured before sourcing so _hook_source_extensions finds agent/local variants
_hook_script_parent() {
  case "$1" in
    */*) printf '%s\n' "${1%/*}" ;;
    *) printf '.\n' ;;
  esac
}

_hook_script_dir() {
  local path="$1" dir target
  while [[ -L "$path" ]]; do
    dir=$(cd -P -- "$(_hook_script_parent "$path")" && pwd) || return 1
    target=$(readlink "$path") || return 1
    [[ "$target" == /* ]] || target="$dir/$target"
    path="$target"
  done
  cd -P -- "$(_hook_script_parent "$path")" && pwd
}

_HOOK_BIN_DIR=$(_hook_script_dir "${BASH_SOURCE[0]}") || {
  echo "${0##*/}: cannot resolve executable path" >&2
  exit 2
}
source "$_HOOK_BIN_DIR/../lib/agentguard/hook-helpers.sh"

# Detect repo type and check for uncommitted changes.
# Ordered by preference: sl (Sapling) > git > jj (Jujutsu).
changes=''
if command -v sl >/dev/null 2>&1 && sl root >/dev/null 2>&1; then
  changes=$(sl status 2>/dev/null | head -20)
elif command -v git >/dev/null 2>&1 && git rev-parse --git-dir >/dev/null 2>&1; then
  changes=$(git status --porcelain --untracked-files=no 2>/dev/null | head -20)
elif command -v jj >/dev/null 2>&1 && jj root >/dev/null 2>&1; then
  changes=$(jj status 2>/dev/null | head -20)
fi
if [ -n "$changes" ]; then
  _hook_context "Uncommitted changes:
$changes"
fi

# Disk usage warning
disk=$(df -h . 2>/dev/null | awk 'NR==2{print $5}' | tr -d '%')
if [ -n "$disk" ] && [ "$disk" -gt 90 ] 2>/dev/null; then
  _hook_context "WARNING: Disk usage at ${disk}%"
fi

_hook_hm_session_start
_hook_source_extensions
_hook_finish
