#!/usr/bin/env bash
# agent-hook-pre-edit — PreToolUse guard for Edit|Write.

set -u
_HOOK_SELF="${AGENTGUARD_HOOK_SELF:-$0}" # captured before sourcing so _hook_source_extensions finds agent/local variants
# shellcheck shell=bash
# BEGIN GENERATED LAUNCHER BOOTSTRAP
# Generated by support/sync-hook-bootstrap; edit the template, not launcher copies.
# shellcheck shell=bash
_agentguard_script_parent() {
  case "$1" in
    */*) printf '%s\n' "${1%/*}" ;;
    *) printf '.\n' ;;
  esac
}

_agentguard_script_dir() {
  local path="$1" dir target
  while [[ -L "$path" ]]; do
    dir=$(cd -P -- "$(_agentguard_script_parent "$path")" && pwd) || return 1
    target=$(readlink "$path") || return 1
    [[ "$target" == /* ]] || target="$dir/$target"
    path="$target"
  done
  cd -P -- "$(_agentguard_script_parent "$path")" && pwd
}
_HOOK_BIN_DIR=$(_agentguard_script_dir "${BASH_SOURCE[0]}") || {
  echo "${0##*/}: cannot resolve executable path" >&2
  exit 2
}
# shellcheck disable=SC1091 # Resolved relative to this symlink-aware launcher.
source "$_HOOK_BIN_DIR/../lib/agentguard/hook-helpers.sh"
# END GENERATED LAUNCHER BOOTSTRAP

_hook_parse_edit_files
[ -z "$AGENTGUARD_EDIT_FILES" ] && exit 0

_pre_edit_code_file() {
  local fp="$1" base
  base="$(basename "$fp")"
  case "$base" in
    AGENTS.md | CLAUDE.md | GEMINI.md | \
      Makefile | Dockerfile | Containerfile | Rakefile | Gemfile | Brewfile | justfile | Justfile)
      return 0
      ;;
  esac
  case "$fp" in
    */.config/agent-rules/*.md)
      return 0
      ;;
  esac
  # Keep this list as a cheap hook-side reminder trigger. Agent rule loading
  # owns the exact fragment set; the pre-edit hook only decides whether an edit
  # is likely to need the global/code/language policy reminder.
  case "$fp" in
    *.c | *.cc | *.cpp | *.cxx | *.h | *.hh | *.hpp | *.hxx | \
      *.m | *.mm | *.rs | *.go | *.zig | *.java | *.kt | *.kts | *.scala | \
      *.js | *.jsx | *.ts | *.tsx | *.mjs | *.cjs | *.vue | *.svelte | \
      *.py | *.rb | *.php | *.lua | *.vim | *.el | *.ex | *.exs | *.erl | *.hrl | \
      *.sh | *.bash | *.zsh | *.fish | *.ps1 | *.awk | *.pl | *.pm | \
      *.sql | *.tf | *.nix | *.yaml | *.yml | *.toml | *.jsonnet)
      return 0
      ;;
  esac
  return 1
}

_pre_edit_comment_reminder() {
  local fp reminder
  reminder="Code edit: apply AGENTS.md > Design Principles, Engineering Workflow, Code Style, and any loaded language-specific rule fragments before editing. Keep ownership clear, scope tight, and use small code/test/review/fix cycles. Add comments for why: invariants, tradeoffs, edge cases, and cross-system assumptions; avoid comments that restate obvious code."
  while IFS= read -r fp; do
    [ -n "$fp" ] || continue
    _pre_edit_code_file "$fp" || continue
    # This is deliberately a reminder, not a lint. The durable rule text lives
    # in the agent-agnostic AGENTS.md. Emit it once per user prompt so it stays
    # near the first code edit without becoming repetitive hook noise during a
    # multi-file refactor.
    _hook_once_per_prompt "code-edit-reminder" || return 0
    # _hook_remind handles both human-visible stderr and model-visible hook
    # context, so callers do not need to duplicate those channels.
    _hook_remind "$reminder"
    return 0
  done <<<"$AGENTGUARD_EDIT_FILES"
}

# Edit churn guard
if ! _hook_flag_enabled "${AGENTGUARD_EDIT_CHURN_BYPASS:-}"; then
  while IFS= read -r _fp; do
    [ -n "$_fp" ] || continue
    _churn_file=$(_hook_edit_churn_file "$_fp")
    if [ -f "$_churn_file" ]; then
      _count=$(_hook_counter_read "$_churn_file")
      if [ "${_count:-0}" -ge "${AGENTGUARD_EDIT_CHURN_BLOCK:-10}" ]; then
        _hook_block "'$(basename "$_fp")' has been edited $_count times this session. Step back and rethink the approach, or set AGENTGUARD_EDIT_CHURN_BYPASS=1 for a deliberate edit pass."
      elif [ "${_count:-0}" -ge "${AGENTGUARD_EDIT_CHURN_WARN:-5}" ]; then
        _hook_warn "'$(basename "$_fp")' has been edited $_count times this session. Consider whether you're making progress; set AGENTGUARD_EDIT_CHURN_BYPASS=1 for a deliberate edit pass."
      fi
    fi
  done <<<"$AGENTGUARD_EDIT_FILES"
fi

# Block edits to secrets files — credentials, keys, and env files must not be
# modified by an agent without explicit human review.
_secrets_file_pattern() {
  local fp="$1" base
  base="$(basename "$fp")"
  # Match on filename alone
  case "$base" in
    .env | .env.* | *.env | \
      id_rsa | id_dsa | id_ecdsa | id_ed25519 | \
      id_rsa.pub | id_dsa.pub | id_ecdsa.pub | id_ed25519.pub | \
      *.pem | *.p12 | *.pfx | *.p8 | *.key | *.keystore | *.jks | \
      credentials | credentials.json | credentials.yaml | credentials.yml | \
      secrets | secrets.json | secrets.yaml | secrets.yml | secrets.toml | \
      .netrc | .pgpass | .npmrc | .pypirc)
      return 0
      ;;
  esac
  # Match on path suffix for directory-qualified names
  case "$fp" in
    */.aws/credentials | */.ssh/config | */.ssh/id_* | */.ssh/authorized_keys | */.ssh/known_hosts)
      return 0
      ;;
  esac
  return 1
}

while IFS= read -r _fp; do
  [ -n "$_fp" ] || continue
  if _secrets_file_pattern "$_fp"; then
    _hook_block "Editing '$_fp' is not allowed — secrets and credential files must be modified manually."
  fi
done <<<"$AGENTGUARD_EDIT_FILES"

_hook_source_extensions
# Broad guidance should reinforce allowed code edits, not consume the
# once-per-prompt marker on an edit that another guard already blocked.
[ -z "$_HOOK_BLOCKED" ] && _pre_edit_comment_reminder
_hook_finish
