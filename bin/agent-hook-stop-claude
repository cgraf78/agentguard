#!/usr/bin/env bash
# agent-hook-stop-claude — Claude-specific Stop extension.
# Sourced by agent-hook-stop via _hook_source_agent.
# Syncs Claude Code memory directories to cloud storage.

_agentguard_claude_stop() {
  local script
  if command -v sync-memory >/dev/null 2>&1; then
    sync-memory
  else
    script=$(find "$HOME/.claude/plugins/cache" -path '*/memory-sync/*/scripts/sync-memory.sh' 2>/dev/null | head -1)
    [ -n "$script" ] && bash "$script"
  fi
}

_agentguard_claude_stop "$@"
