#!/usr/bin/env bash
# agent-hook-post-edit — PostToolUse handler for Edit|Write.
# Auto-formats edited files.

set -u
_HOOK_SELF="${AGENTGUARD_HOOK_SELF:-$0}" # captured before sourcing so _hook_source_extensions finds agent/local variants
_hook_script_parent() {
  case "$1" in
    */*) printf '%s\n' "${1%/*}" ;;
    *) printf '.\n' ;;
  esac
}

_hook_script_dir() {
  local path="$1" dir target
  while [[ -L "$path" ]]; do
    dir=$(cd -P -- "$(_hook_script_parent "$path")" && pwd) || return 1
    target=$(readlink "$path") || return 1
    [[ "$target" == /* ]] || target="$dir/$target"
    path="$target"
  done
  cd -P -- "$(_hook_script_parent "$path")" && pwd
}

_HOOK_BIN_DIR=$(_hook_script_dir "${BASH_SOURCE[0]}") || {
  echo "${0##*/}: cannot resolve executable path" >&2
  exit 2
}
source "$_HOOK_BIN_DIR/../lib/agentguard/hook-helpers.sh"

_hook_parse_edit_files

_post_edit_sley_file() {
  local fp="$1" abs_fp dir caller
  [ -n "$fp" ] || return 0
  [ -f "$fp" ] || return 0

  # Post-edit policy has one owner: Sley. If the command is missing, the
  # install is incomplete and the hook should fail loudly instead of silently
  # skipping save-time formatting.
  _hook_require_sley || return $?

  # Resolve `$fp` to an absolute path BEFORE the `cd` below. Without this, a
  # relative path like `src/main.js` would re-resolve against the new cwd
  # after `cd "$dir"` and the formatter would look for `src/src/main.js`,
  # silently no-op'ing on every relative-path edit.
  case "$fp" in
    /*) abs_fp="$fp" ;;
    *) abs_fp="$PWD/$fp" ;;
  esac

  dir=$(dirname "$abs_fp")
  caller=$(_hook_agent_name)
  (
    # Detect the repo from the edited file's directory, not from the agent's
    # process cwd. Agents often edit absolute paths while sitting elsewhere.
    cd "$dir" || exit 0
    export SLEY_CALLER="$caller"
    sley hook format-file "$abs_fp" >/dev/null 2>&1 || true
  )
}

while IFS= read -r _fp; do
  [ -n "$_fp" ] || continue
  _post_edit_sley_file "$_fp" || exit $?
done <<<"$AGENTGUARD_EDIT_FILES"

# Track edit churn per file
if [ -n "$AGENTGUARD_EDIT_FILES" ]; then
  while IFS= read -r _fp; do
    [ -n "$_fp" ] || continue
    _churn_file=$(_hook_edit_churn_file "$_fp")
    _hook_counter_increment "$_churn_file"
  done <<<"$AGENTGUARD_EDIT_FILES"
fi

# Keep memory refresh policy in `hm`; this hook only supplies the edit event.
_hook_hm_tool_complete
_hook_source_extensions
_hook_finish
