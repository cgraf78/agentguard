#!/bin/sh -p
# shellcheck shell=bash
# agentguard-classify-command — emit conservative command facts as JSON.

# Privileged Bash suppresses exported-function imports but leaves their raw
# environment entries intact. Detect those entries structurally, then rebuild
# the environment from Bash's exported-variable table before a candidate
# wrapper or later non-privileged Bash can import them. Values remain argv
# entries throughout, so embedded newlines and quotes are preserved.
/usr/bin/awk '
  BEGIN {
    for (name in ENVIRON) {
      if (length(name) >= 12 && substr(name, 1, 10) == "BASH_FUNC_" &&
          substr(name, length(name) - 1) == "%%") {
        exit 0
      }
    }
    exit 1
  }
' </dev/null
_agentguard_awk_status=$?
if [ "$_agentguard_awk_status" -eq 0 ]; then
  _agentguard_scrub_reentry=1
  if [ -n "${AGENTGUARD_CLASSIFY_COMMAND_REEXEC:-}" ]; then
    if [ -n "${BASH_VERSION:-}" ] && [ -n "${BASH:-}" ] &&
      (eval 'declare -A _agentguard_probe=([identity]=bash); [[ ${_agentguard_probe[identity]} == bash ]]') \
        2>/dev/null; then
      set -- "$BASH" --noprofile --norc -p "$0" "$@"
    else
      # A non-Bash shell carrying the re-exec marker cannot reach candidate
      # discovery or non-privileged Bash; let the main bootstrap fail closed.
      _agentguard_scrub_reentry=0
    fi
  else
    set -- /bin/sh -p "$0" "$@"
  fi
  if [ "$_agentguard_scrub_reentry" -eq 1 ]; then
    _agentguard_scrub_bash_probe=$(BASH_ENV='' ENV='' \
      /bin/bash --noprofile --norc -p -c '
        case "$-" in *p*) ;; *) exit 1 ;; esac
        [ -n "${BASH_VERSION:-}" ] || exit 1
        printf "%s\n" agentguard-scrub-bash-v1
      ' </dev/null 2>/dev/null)
    _agentguard_scrub_bash_status=$?
    if [ "$_agentguard_scrub_bash_status" -ne 0 ] ||
      [ "$_agentguard_scrub_bash_probe" != agentguard-scrub-bash-v1 ]; then
      echo "agentguard-classify-command: cannot start trusted /bin/bash environment scrub; refusing unguarded execution" >&2
      exit 2
    fi
    BASH_ENV='' ENV='' /bin/bash --noprofile --norc -p -c '
      _agentguard_env_probe=$(
        /usr/bin/env -i BASH_ENV= ENV= /bin/sh -p -c \
          '\''printf "%s\n" agentguard-scrub-env-v1'\'' </dev/null 2>/dev/null
      )
      if [[ $? -ne 0 || $_agentguard_env_probe != agentguard-scrub-env-v1 ]]; then
        echo "agentguard-classify-command: cannot rebuild a safe environment with /usr/bin/env; refusing unguarded execution" >&2
        exit 2
      fi
      _agentguard_environment=()
      while IFS= read -r _agentguard_name; do
        case "$_agentguard_name" in BASH_ENV | ENV) continue ;; esac
        _agentguard_environment+=("$_agentguard_name=${!_agentguard_name}")
      done < <(compgen -e)
      shopt -s execfail
      exec /usr/bin/env -i "${_agentguard_environment[@]}" BASH_ENV= ENV= "$@"
      echo "agentguard-classify-command: cannot rebuild a safe environment with /usr/bin/env; refusing unguarded execution" >&2
      exit 2
    ' agentguard-environment-scrub "$@"
    _agentguard_scrub_status=$?
    case "$_agentguard_scrub_status" in
      0 | 2) exit "$_agentguard_scrub_status" ;;
      *)
        echo "agentguard-classify-command: trusted environment scrub failed; refusing unguarded execution" >&2
        exit 2
        ;;
    esac
  fi
elif [ "$_agentguard_awk_status" -ne 1 ]; then
  echo "agentguard-classify-command: cannot inspect the environment with /usr/bin/awk; refusing unguarded execution" >&2
  exit 2
fi

# Bootstrap through the platform's fixed POSIX shell so PATH cannot substitute
# a fake interpreter before this code runs. The classifier needs Bash 4+.
_agentguard_needs_modern_bash=1
_agentguard_bash_major=${BASH_VERSION%%.*}
case "$_agentguard_bash_major" in
  "" | *[!0-9]*) ;;
  *)
    if [ "$_agentguard_bash_major" -ge 4 ] &&
      [ "${AGENTGUARD_CLASSIFY_COMMAND_REEXEC:-}" = 1 ]; then
      case "$-" in
        *p*)
          if (eval 'declare -A _agentguard_probe=([identity]=bash); [[ ${_agentguard_probe[identity]} == bash ]]') \
            2>/dev/null; then
            _agentguard_needs_modern_bash=0
          fi
          ;;
      esac
    fi
    ;;
esac
if [ "$_agentguard_needs_modern_bash" -eq 1 ]; then
  if [ -z "${AGENTGUARD_CLASSIFY_COMMAND_REEXEC:-}" ]; then
    _agentguard_home_bash=""
    case "${HOME:-}" in /*) _agentguard_home_bash="$HOME/.local/bin/bash" ;; esac
    for _agentguard_bash in \
      "$_agentguard_home_bash" /opt/homebrew/bin/bash /usr/local/bin/bash /bin/bash; do
      [ -x "$_agentguard_bash" ] || continue
      # shellcheck disable=SC2016 # The candidate Bash expands the probe body.
      _agentguard_bash_probe=$(BASH_ENV='' ENV='' "$_agentguard_bash" --noprofile --norc -p -c '
        case "$-" in *p*) ;; *) exit 1 ;; esac
        [ -n "${BASH_VERSION:-}" ] || exit 1
        case "${BASH_VERSINFO[0]:-}" in "" | *[!0-9]*) exit 1 ;; esac
        [ "${BASH_VERSINFO[0]}" -ge 4 ] || exit 1
        declare -A _agentguard_probe=([identity]=bash) || exit 1
        [[ ${_agentguard_probe[identity]} == bash ]] || exit 1
        printf "%s\n" agentguard-modern-bash-v1
      ' </dev/null 2>/dev/null) || continue
      if [ "$_agentguard_bash_probe" = agentguard-modern-bash-v1 ]; then
        BASH_ENV='' ENV='' AGENTGUARD_CLASSIFY_COMMAND_REEXEC=1 \
          exec "$_agentguard_bash" --noprofile --norc -p "$0" "$@"
      fi
    done
  fi
  echo "agentguard-classify-command: Bash 4 or newer is required" >&2
  exit 2
fi
unset BASH_ENV ENV AGENTGUARD_CLASSIFY_COMMAND_REEXEC
set +p
unset _agentguard_awk_status _agentguard_scrub_reentry \
  _agentguard_scrub_bash_probe _agentguard_scrub_bash_status \
  _agentguard_scrub_status _agentguard_needs_modern_bash _agentguard_bash_major \
  _agentguard_home_bash _agentguard_bash _agentguard_bash_probe

set -euo pipefail

_usage() {
  cat <<'EOF'
usage: agentguard-classify-command [--json] [--json-lines] [--] [command...]

Classify executable command words from Bash-like command text and print JSON:
  {"commands":[{"fragment":"...","command":"...","basename":"..."}]}

With no command argument, command text is read from stdin.
With --json-lines, read one command per stdin line and print one JSON object
per line: {"input":"...","commands":[...]}.
EOF
}

# BEGIN GENERATED LAUNCHER BOOTSTRAP
# Generated by support/sync-hook-bootstrap; edit the template, not launcher copies.
# shellcheck shell=bash
_agentguard_script_parent() {
  case "$1" in
    */*) printf '%s\n' "${1%/*}" ;;
    *) printf '.\n' ;;
  esac
}

_agentguard_script_dir() {
  local path="$1" dir target
  while [[ -L "$path" ]]; do
    dir=$(cd -P -- "$(_agentguard_script_parent "$path")" && pwd) || return 1
    target=$(readlink "$path") || return 1
    [[ "$target" == /* ]] || target="$dir/$target"
    path="$target"
  done
  cd -P -- "$(_agentguard_script_parent "$path")" && pwd
}
# END GENERATED LAUNCHER BOOTSTRAP

_json_lines=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --json)
      shift
      ;;
    --json-lines)
      _json_lines=1
      shift
      ;;
    -h | --help)
      _usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf 'agentguard-classify-command: unknown option: %s\n' "$1" >&2
      _usage >&2
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

_bin_dir=$(_agentguard_script_dir "${BASH_SOURCE[0]}") || {
  echo "agentguard-classify-command: cannot resolve executable path" >&2
  exit 2
}

# shellcheck source=../lib/agentguard/hook-command-classifier.sh
# shellcheck disable=SC1091 # sibling module resolved from this script's dir.
source "$_bin_dir/../lib/agentguard/hook-command-classifier.sh"

if [ "$_json_lines" -eq 1 ]; then
  if [ "$#" -gt 0 ]; then
    printf 'agentguard-classify-command: --json-lines reads commands from stdin\n' >&2
    exit 2
  fi
  while IFS= read -r _command_text || [ -n "$_command_text" ]; do
    agentguard_classify_command_record_json "$_command_text"
  done
  exit 0
fi

if [ "$#" -gt 0 ]; then
  _command_text="$*"
else
  _command_text="$(cat)"
fi

agentguard_classify_command_json "$_command_text"
