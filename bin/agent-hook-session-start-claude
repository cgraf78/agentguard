#!/usr/bin/env bash
# agent-hook-session-start-claude — Claude-specific SessionStart extension.
# Sourced by agent-hook-session-start via _hook_source_agent.
# Daily plugin update.

_agentguard_claude_session_start() {
  local stamp
  if command -v claude-templates >/dev/null 2>&1; then
    stamp="/tmp/claude-plugins-updated-$(id -u)"
    if [ ! -f "$stamp" ] || [ "$(date +%Y%m%d)" != "$(cat "$stamp" 2>/dev/null)" ]; then
      claude-templates update --quiet >/dev/null 2>&1 &
      date +%Y%m%d >"$stamp"
    fi
  fi
}

_agentguard_claude_session_start "$@"
