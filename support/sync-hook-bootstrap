#!/usr/bin/env bash
# Synchronize self-contained bootstrap blocks embedded in public launchers.

set -euo pipefail

root=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)
template="$root/support/script-resolver.sh.template"
secure_template="$root/support/secure-launcher.sh.template"
manifest="$root/support/launcher-bootstrap.manifest"
check=false

case "${1:-}" in
  "") ;;
  --check) check=true ;;
  *)
    printf 'usage: %s [--check]\n' "${0##*/}" >&2
    exit 2
    ;;
esac

replace_generated_block() {
  local block="$1" launcher="$2" generated="$3" marker_pattern="$4"
  local indent_replacement="$5"
  awk -v marker_pattern="$marker_pattern" \
    -v indent_replacement="$indent_replacement" '
    NR == FNR {
      replacement[++replacement_count] = $0
      next
    }
    !replacing &&
      $0 ~ "^[[:space:]]*# BEGIN GENERATED " marker_pattern " BOOTSTRAP$" {
      if (!replaced) {
        indent = ""
        if (indent_replacement == "true") {
          indent = $0
          sub(/[^[:space:]].*$/, "", indent)
        }
        for (i = 1; i <= replacement_count; i++) {
          if (replacement[i] == "") print ""
          else print indent replacement[i]
        }
      }
      replacing = 1
      replaced = 1
      next
    }
    replacing &&
      $0 ~ "^[[:space:]]*# END GENERATED " marker_pattern " BOOTSTRAP$" {
      replacing = 0
      next
    }
    replaced &&
      $0 ~ "^[[:space:]]*# END GENERATED " marker_pattern " BOOTSTRAP$" {
      next
    }
    !replacing { print }
    END { if (!replaced || replacing) exit 3 }
  ' "$block" "$launcher" >"$generated"
}

parse_manifest() {
  awk '
    /^[[:space:]]*$/ { next }
    NF != 2 {
      printf "invalid manifest line %d: expected exactly two fields\n", NR > "/dev/stderr"
      invalid = 1
      next
    }
    {
      line_invalid = 0
      entries++
    }
    $1 !~ /^(hook|classifier|secure-hook|secure-classifier)$/ {
      printf "invalid launcher kind on manifest line %d: %s\n", NR, $1 > "/dev/stderr"
      invalid = 1
      line_invalid = 1
    }
    $2 !~ /^[A-Za-z0-9._\/-]+$/ || $2 ~ /^\// || $2 ~ /\/\// ||
      $2 ~ /(^|\/)\.\.?(\/|$)/ {
      printf "unsafe launcher path on manifest line %d: %s\n", NR, $2 > "/dev/stderr"
      invalid = 1
      line_invalid = 1
    }
    seen[$2]++ {
      printf "duplicate launcher path on manifest line %d: %s\n", NR, $2 > "/dev/stderr"
      invalid = 1
      line_invalid = 1
    }
    !line_invalid { print $1 "\t" $2 }
    END {
      if (entries == 0) {
        print "sync-hook-bootstrap: manifest has no launchers" > "/dev/stderr"
        invalid = 1
      }
      exit invalid
    }
  ' "$manifest"
}

find_manifest_entry() {
  local wanted_path="$1" entry_index
  manifest_match=-1
  for ((entry_index = 0; entry_index < manifest_count; entry_index++)); do
    if [[ "${manifest_paths[entry_index]}" == "$wanted_path" ]]; then
      manifest_match=$entry_index
      return 0
    fi
  done
  return 1
}

find_expected_launcher() {
  local wanted_path="$1" entry_index
  for ((entry_index = 0; entry_index < expected_count; entry_index++)); do
    if [[ "${expected_paths[entry_index]}" == "$wanted_path" ]]; then
      return 0
    fi
  done
  return 1
}

require_launcher_entry() {
  local relative_path="$1" expected_kind="$2" actual_kind
  if ! find_manifest_entry "$relative_path"; then
    printf '%s\n' "missing manifest entry: $relative_path" >&2
    return 1
  fi
  actual_kind=${manifest_kinds[manifest_match]}
  if [[ "$actual_kind" != "$expected_kind" ]]; then
    printf 'launcher kind mismatch for %s: expected %s, found %s\n' \
      "$relative_path" "$expected_kind" "$actual_kind" >&2
    return 1
  fi
  if ! find_expected_launcher "$relative_path"; then
    expected_paths[expected_count]="$relative_path"
    expected_count=$((expected_count + 1))
  fi
}

make_secure_block() {
  local block="$1" entry_name="$2" secure_part="$3"
  local opening_indent closing_indent
  if [[ "$secure_part" == PROLOGUE ]]; then
    opening_indent=''
    closing_indent='    '
  else
    opening_indent='    '
    closing_indent=''
  fi

  {
    printf '%s# BEGIN GENERATED SECURE LAUNCHER %s BOOTSTRAP\n' \
      "$opening_indent" "$secure_part" || return
    printf '%s%s\n' "$opening_indent" \
      '# Generated secure launcher; edit support/secure-launcher.sh.template, not launcher copies.' || return
    awk -v entry_name="$entry_name" -v part="$secure_part" '
      $0 ~ /^[[:space:]]*# @APPLICATION@$/ {
        after_application = 1
        next
      }
      (part == "PROLOGUE" && !after_application) ||
        (part == "EPILOGUE" && after_application) {
        gsub(/@ENTRY_NAME@/, entry_name)
        print
      }
    ' "$secure_template" || return
    printf '%s# END GENERATED SECURE LAUNCHER %s BOOTSTRAP\n' \
      "$closing_indent" "$secure_part" || return
  } >"$block"
}

make_resolver_block() {
  local block="$1" resolver_kind="$2"
  {
    printf '%s\n' '# BEGIN GENERATED LAUNCHER BOOTSTRAP' || return
    printf '%s\n' \
      '# Generated by support/sync-hook-bootstrap; edit the template, not launcher copies.' || return
    command cat "$template" || return
    if [[ "$resolver_kind" == hook ]]; then
      # shellcheck disable=SC2016 # Generated variables expand in each launcher.
      printf '%s\n' \
        '_HOOK_BIN_DIR=$(_agentguard_script_dir "${BASH_SOURCE[0]}") || {' \
        '  echo "${0##*/}: cannot resolve executable path" >&2' \
        '  exit 2' \
        '}' \
        '# shellcheck disable=SC1091 # Resolved relative to this symlink-aware launcher.' \
        'source "$_HOOK_BIN_DIR/../lib/agentguard/hook-helpers.sh"' || return
    fi
    printf '%s\n' '# END GENERATED LAUNCHER BOOTSTRAP' || return
  } >"$block"
}

apply_generated_block() {
  local block="$1" input="$2" output="$3" marker_pattern="$4"
  local relative_path="$5" indent_replacement="${6:-true}"
  if ! replace_generated_block \
    "$block" "$input" "$output" "$marker_pattern" \
    "$indent_replacement"; then
    printf '%s\n' "missing or incomplete generated block: $relative_path" >&2
    return 1
  fi
}

read_text_file() {
  local path="$1" captured
  if captured=$(
    command cat "$path" || exit $?
    printf x
  ); then
    text_file_contents=${captured%?}
    return 0
  fi
  return 2
}

compare_text_files() {
  local left_contents right_contents
  if ! read_text_file "$1"; then
    return 2
  fi
  left_contents=$text_file_contents
  if ! read_text_file "$2"; then
    return 2
  fi
  right_contents=$text_file_contents
  if [[ "$left_contents" == "$right_contents" ]]; then
    return 0
  fi
  return 1
}

# Validate all deterministic inputs before allocating staging space or touching
# a launcher. This keeps malformed manifests and missing templates fail-safe.
if [[ ! -f "$manifest" || ! -r "$manifest" ]]; then
  printf '%s\n' "missing launcher manifest: $manifest" >&2
  exit 1
fi
if ! manifest_records=$(parse_manifest); then
  exit 1
fi
if [[ ! -f "$template" || ! -r "$template" ]]; then
  printf '%s\n' "missing resolver template: $template" >&2
  exit 1
fi

manifest_kinds=()
manifest_paths=()
manifest_count=0
while IFS=$'\t' read -r kind relative_path; do
  manifest_kinds[manifest_count]="$kind"
  manifest_paths[manifest_count]="$relative_path"
  manifest_count=$((manifest_count + 1))
done <<<"$manifest_records"

expected_paths=()
expected_count=0
require_launcher_entry bin/agent-hook-pre-bash secure-hook
require_launcher_entry bin/agentguard-classify-command secure-classifier

# Base hooks use unsuffixed names. Agent-specific and local extension scripts
# are deliberately separate and do not load the shared hook bootstrap.
for launcher in "$root"/bin/agent-hook-*; do
  [[ -e "$launcher" ]] || continue
  relative_path="${launcher#"$root"/}"
  case "$relative_path" in
    *-claude | *-codex | *-gemini | *-work) continue ;;
    bin/agent-hook-pre-bash) continue ;;
  esac
  require_launcher_entry "$relative_path" hook
done

# Any executable family can opt into generated bootstrap management. Discover
# those launchers by their generated block rather than by a name-only allowlist.
for launcher in "$root"/bin/*; do
  [[ -f "$launcher" ]] || continue
  relative_path="${launcher#"$root"/}"
  inventory_status=0
  awk '
    /^[[:space:]]*# BEGIN GENERATED (HOOK|LAUNCHER) BOOTSTRAP$/ {
      found = 1
    }
    END { exit !found }
  ' "$launcher" || inventory_status=$?
  case "$inventory_status" in
    0) ;;
    1) continue ;;
    *)
      printf '%s\n' "cannot inspect generated launcher: $relative_path" >&2
      exit 1
      ;;
  esac
  if find_expected_launcher "$relative_path"; then
    continue
  fi
  if ! find_manifest_entry "$relative_path"; then
    printf '%s\n' "unlisted generated launcher: $relative_path" >&2
    exit 1
  fi
  expected_paths[expected_count]="$relative_path"
  expected_count=$((expected_count + 1))
done

for ((index = 0; index < manifest_count; index++)); do
  relative_path=${manifest_paths[index]}
  if ! find_expected_launcher "$relative_path"; then
    printf '%s\n' "unexpected manifest launcher: $relative_path" >&2
    exit 1
  fi
done

for ((index = 0; index < expected_count; index++)); do
  relative_path=${expected_paths[index]}
  launcher="$root/$relative_path"
  if [[ ! -f "$launcher" || ! -x "$launcher" ]]; then
    printf '%s\n' "missing or non-executable launcher: $relative_path" >&2
    exit 1
  fi
done

if [[ ! -f "$secure_template" || ! -r "$secure_template" ]]; then
  printf '%s\n' "missing secure launcher template: $secure_template" >&2
  exit 1
fi
if ! secure_application_markers=$(awk '
  /^[[:space:]]*# @APPLICATION@$/ { count++ }
  END { print count + 0 }
' "$secure_template"); then
  printf '%s\n' "cannot inspect secure launcher template: $secure_template" >&2
  exit 1
fi
if [[ "$secure_application_markers" -ne 1 ]]; then
  printf 'secure launcher template requires exactly one application marker; found %s: %s\n' \
    "$secure_application_markers" "$secure_template" >&2
  exit 1
fi

stage_dir=''
install_temps=()
cleanup_stage() {
  local rc=$? install_temp
  trap - EXIT
  for install_temp in "${install_temps[@]+"${install_temps[@]}"}"; do
    if [[ -n "$install_temp" ]]; then
      command rm -f -- "$install_temp" || :
    fi
  done
  if [[ -n "$stage_dir" && -d "$stage_dir" ]]; then
    command rm -rf -- "$stage_dir" || :
  fi
  return "$rc"
}
trap cleanup_stage EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

if ! stage_dir=$(umask 077 && mktemp -d "${TMPDIR:-/tmp}/agentguard-sync.XXXXXX"); then
  printf '%s\n' "cannot allocate launcher staging directory" >&2
  exit 1
fi
launcher_paths=()
relative_paths=()
staged_paths=()
dirty_launchers=()
for ((index = 0; index < manifest_count; index++)); do
  kind=${manifest_kinds[index]}
  relative_path=${manifest_paths[index]}
  launcher="$root/$relative_path"
  staged="$stage_dir/launcher.$index"
  if ! command cat "$launcher" >"$staged"; then
    printf '%s\n' "cannot stage launcher: $relative_path" >&2
    exit 1
  fi

  secure=false
  case "$kind" in
    hook | classifier) resolver_kind="$kind" ;;
    secure-hook)
      resolver_kind=hook
      secure=true
      ;;
    secure-classifier)
      resolver_kind=classifier
      secure=true
      ;;
  esac

  if "$secure"; then
    entry_name=${relative_path##*/}
    for secure_part in PROLOGUE EPILOGUE; do
      block="$stage_dir/block.$index.$secure_part"
      generated="$stage_dir/generated.$index.$secure_part"
      if ! make_secure_block "$block" "$entry_name" "$secure_part"; then
        printf '%s\n' "cannot generate secure launcher block: $relative_path" >&2
        exit 1
      fi
      apply_generated_block \
        "$block" "$staged" "$generated" \
        "SECURE LAUNCHER $secure_part" "$relative_path" false
      if ! command mv "$generated" "$staged"; then
        printf '%s\n' "cannot stage generated launcher: $relative_path" >&2
        exit 1
      fi
    done
  fi

  block="$stage_dir/block.$index.resolver"
  generated="$stage_dir/generated.$index.resolver"
  if ! make_resolver_block "$block" "$resolver_kind"; then
    printf '%s\n' "cannot generate resolver block: $relative_path" >&2
    exit 1
  fi
  apply_generated_block \
    "$block" "$staged" "$generated" '(HOOK|LAUNCHER)' "$relative_path"
  if ! command mv "$generated" "$staged"; then
    printf '%s\n' "cannot stage generated launcher: $relative_path" >&2
    exit 1
  fi
  if ! command bash -n "$staged"; then
    printf '%s\n' "generated launcher does not parse: $relative_path" >&2
    exit 1
  fi

  launcher_paths[index]="$launcher"
  relative_paths[index]="$relative_path"
  staged_paths[index]="$staged"
  compare_status=0
  compare_text_files "$launcher" "$staged" || compare_status=$?
  case "$compare_status" in
    0) dirty_launchers[index]=false ;;
    1) dirty_launchers[index]=true ;;
    *)
      printf '%s\n' "cannot compare generated launcher: $relative_path" >&2
      exit 1
      ;;
  esac
done

status=0
for ((index = 0; index < manifest_count; index++)); do
  if "${dirty_launchers[index]}"; then
    if "$check"; then
      printf '%s\n' "out of date: ${relative_paths[index]}" >&2
      status=1
    fi
  fi
done
if "$check"; then
  exit "$status"
fi

# Prepare mode-preserving, same-directory install files only after every
# launcher candidate validates. Each rename below is atomic, though a portable
# shell cannot make the set of renames atomic as one transaction.
for ((index = 0; index < manifest_count; index++)); do
  if "${dirty_launchers[index]}"; then
    launcher_dir=${launcher_paths[index]%/*}
    if ! install_temp=$(mktemp "$launcher_dir/.agentguard-sync.XXXXXX"); then
      printf '%s\n' "cannot allocate launcher update: ${relative_paths[index]}" >&2
      exit 1
    fi
    install_temps[index]="$install_temp"
    if ! command cp -p "${launcher_paths[index]}" "$install_temp" ||
      ! command cat "${staged_paths[index]}" >"$install_temp"; then
      printf '%s\n' "cannot prepare launcher update: ${relative_paths[index]}" >&2
      exit 1
    fi
    if ! command bash -n "$install_temp"; then
      printf '%s\n' "cannot prepare launcher update: ${relative_paths[index]}" >&2
      exit 1
    fi
    compare_status=0
    compare_text_files \
      "${staged_paths[index]}" "$install_temp" || compare_status=$?
    case "$compare_status" in
      0) ;;
      1)
        printf '%s\n' "prepared launcher differs: ${relative_paths[index]}" >&2
        exit 1
        ;;
      *)
        printf '%s\n' "cannot verify launcher update: ${relative_paths[index]}" >&2
        exit 1
        ;;
    esac
  fi
done

for ((index = 0; index < manifest_count; index++)); do
  if "${dirty_launchers[index]}"; then
    if ! command mv -f \
      "${install_temps[index]}" "${launcher_paths[index]}"; then
      printf '%s\n' "cannot install launcher: ${relative_paths[index]}" >&2
      exit 1
    fi
    install_temps[index]=''
    printf '%s\n' "updated: ${relative_paths[index]}"
  fi
done
