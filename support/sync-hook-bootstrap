#!/usr/bin/env bash
# Synchronize the self-contained resolver embedded in public launchers.

set -euo pipefail

root=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)
template="$root/support/script-resolver.sh.template"
manifest="$root/support/launcher-bootstrap.manifest"
check=false

case "${1:-}" in
  "") ;;
  --check) check=true ;;
  *)
    printf 'usage: %s [--check]\n' "${0##*/}" >&2
    exit 2
    ;;
esac

status=0
found=0
while read -r kind relative_path; do
  [[ -n "$kind" && -n "$relative_path" ]] || continue
  launcher="$root/$relative_path"
  if [[ ! -f "$launcher" || ! -x "$launcher" ]]; then
    printf '%s\n' "missing launcher: $relative_path" >&2
    status=1
    continue
  fi
  case "$kind" in
    hook | classifier) ;;
    *)
      printf '%s\n' "invalid launcher kind '$kind': $relative_path" >&2
      status=1
      continue
      ;;
  esac
  found=$((found + 1))

  block=$(mktemp "${TMPDIR:-/tmp}/agentguard-block.XXXXXX")
  generated=$(mktemp "${TMPDIR:-/tmp}/agentguard-launcher.XXXXXX")
  {
    printf '%s\n' '# BEGIN GENERATED LAUNCHER BOOTSTRAP'
    printf '%s\n' '# Generated by support/sync-hook-bootstrap; edit the template, not launcher copies.'
    command cat "$template"
    if [[ "$kind" == hook ]]; then
      # shellcheck disable=SC2016 # Generated variables expand in each launcher.
      printf '%s\n' \
        '_HOOK_BIN_DIR=$(_agentguard_script_dir "${BASH_SOURCE[0]}") || {' \
        '  echo "${0##*/}: cannot resolve executable path" >&2' \
        '  exit 2' \
        '}' \
        '# shellcheck disable=SC1091 # Resolved relative to this symlink-aware launcher.' \
        'source "$_HOOK_BIN_DIR/../lib/agentguard/hook-helpers.sh"'
    fi
    printf '%s\n' '# END GENERATED LAUNCHER BOOTSTRAP'
  } >"$block"

  if ! awk '
    NR == FNR {
      replacement = replacement $0 "\n"
      next
    }
    !replacing && ($0 == "# BEGIN GENERATED HOOK BOOTSTRAP" ||
                    $0 == "# BEGIN GENERATED LAUNCHER BOOTSTRAP") {
      if (!replaced) {
        printf "%s", replacement
      }
      replacing = 1
      replaced = 1
      next
    }
    replacing && ($0 == "# END GENERATED HOOK BOOTSTRAP" ||
                   $0 == "# END GENERATED LAUNCHER BOOTSTRAP") {
      replacing = 0
      next
    }
    replaced && ($0 == "# END GENERATED HOOK BOOTSTRAP" ||
                 $0 == "# END GENERATED LAUNCHER BOOTSTRAP") {
      next
    }
    !replacing { print }
    END { if (!replaced || replacing) exit 3 }
  ' "$block" "$launcher" >"$generated"; then
    printf '%s\n' "missing or incomplete generated block: $relative_path" >&2
    status=1
    rm -f "$block" "$generated"
    continue
  fi

  if ! cmp -s "$generated" "$launcher"; then
    if "$check"; then
      printf '%s\n' "out of date: $relative_path" >&2
      status=1
    else
      command cat "$generated" >"$launcher"
      printf '%s\n' "updated: $relative_path"
    fi
  fi
  rm -f "$block" "$generated"
done <"$manifest"

# Base hooks use unsuffixed names. Agent-specific and local extension scripts
# are deliberately separate and do not load the shared hook bootstrap.
for launcher in "$root"/bin/agent-hook-*; do
  relative_path="${launcher#"$root/"}"
  case "$relative_path" in
    *-claude | *-codex | *-gemini | *-work) continue ;;
  esac
  if ! awk -v path="$relative_path" '$2 == path { found = 1 } END { exit !found }' "$manifest"; then
    printf '%s\n' "unlisted base hook: $relative_path" >&2
    status=1
  fi
done

if [[ "$found" -eq 0 ]]; then
  printf '%s\n' "sync-hook-bootstrap: manifest has no launchers" >&2
  exit 1
fi
exit "$status"
