# shellcheck shell=bash
case "$-" in
  *p*)
    # These inherited controls alter shell semantics before the launcher can
    # defend itself. Do not unset BASH_XTRACEFD because that closes its fd.
    set +o posix
    unset FUNCNEST POSIXLY_CORRECT BASH_COMPAT
    export -n BASH_XTRACEFD 2>/dev/null || :

    # Bash uses fd 255 internally and older supported releases can crash when a
    # bootstrap redirection selects 256 or above. Treat 254 as the portable
    # ceiling and fail closed when two private descriptors are unavailable.
    _agentguard_private_fd_limit=$(ulimit -n 2>/dev/null) ||
      _agentguard_private_fd_limit=255
    case "$_agentguard_private_fd_limit" in
      unlimited) _agentguard_private_fd_limit=255 ;;
      "" | *[!0-9]*) _agentguard_private_fd_limit=255 ;;
    esac
    [ "$_agentguard_private_fd_limit" -le 255 ] ||
      _agentguard_private_fd_limit=255

    _agentguard_fd_is_open() {
      local _agentguard_fd=$1
      if eval ": <&$_agentguard_fd" 2>/dev/null; then
        return 0
      fi
      eval ": >&$_agentguard_fd" 2>/dev/null
    }

    _agentguard_reserve_fd() {
      local _agentguard_result_name=$1 _agentguard_redirection=$2
      local _agentguard_fd=3

      while [ "$_agentguard_fd" -lt "$_agentguard_private_fd_limit" ]; do
        if ! _agentguard_fd_is_open "$_agentguard_fd"; then
          if eval "exec $_agentguard_fd$_agentguard_redirection" 2>/dev/null; then
            printf -v "$_agentguard_result_name" '%s' "$_agentguard_fd"
            return 0
          fi
          return 1
        fi
        _agentguard_fd=$((_agentguard_fd + 1))
      done
      return 1
    }

    _agentguard_reserve_stdin() {
      local _agentguard_fd=3

      while [ "$_agentguard_fd" -lt "$_agentguard_private_fd_limit" ]; do
        if ! _agentguard_fd_is_open "$_agentguard_fd"; then
          if eval "exec $_agentguard_fd<&0" 2>/dev/null; then
            _agentguard_saved_stdin_fd=$_agentguard_fd
            _agentguard_stdin_state="read"
            return 0
          fi
          if eval "exec $_agentguard_fd>&0" 2>/dev/null; then
            _agentguard_saved_stdin_fd=$_agentguard_fd
            _agentguard_stdin_state="write"
            return 0
          fi
          return 2
        fi
        _agentguard_fd=$((_agentguard_fd + 1))
      done
      return 1
    }

    _agentguard_prepare_private_descriptors() {
      _agentguard_reserve_fd _agentguard_saved_stdout_fd '>&1' || return 1
      _agentguard_saved_stdin_fd=""
      _agentguard_stdin_state=closed
      _agentguard_reserve_stdin
      _agentguard_stdin_status=$?
      if [ "$_agentguard_stdin_status" -eq 1 ]; then
        # shellcheck disable=SC2154 # Assigned by _agentguard_reserve_fd.
        eval "exec $_agentguard_saved_stdout_fd>&-"
        unset _agentguard_saved_stdout_fd _agentguard_saved_stdin_fd \
          _agentguard_stdin_state _agentguard_stdin_status
        return 1
      fi
      unset _agentguard_stdin_status
    }

    _agentguard_close_private_descriptors() {
      # shellcheck disable=SC2154 # Assigned by _agentguard_reserve_fd.
      eval "exec $_agentguard_saved_stdout_fd>&-"
      if [ "$_agentguard_stdin_state" != closed ]; then
        eval "exec $_agentguard_saved_stdin_fd<&-"
      fi
      unset _agentguard_saved_stdout_fd _agentguard_saved_stdin_fd \
        _agentguard_stdin_state
    }

    _agentguard_environment_scan=$(/usr/bin/awk '
  BEGIN {
    dirty = 0
    for (name in ENVIRON) {
      if (length(name) >= 12 && substr(name, 1, 10) == "BASH_FUNC_" &&
          substr(name, length(name) - 1) == "%%") {
        dirty = 1
      }
    }
    if (dirty) print "agentguard-environment-dirty-v2"
    else print "agentguard-environment-clean-v2"
    exit 0
  }
' </dev/null)
    _agentguard_environment_scan_status=$?
    case "$_agentguard_environment_scan_status:$_agentguard_environment_scan" in
      0:agentguard-environment-clean-v2) ;;
      0:agentguard-environment-dirty-v2)
        _agentguard_bash_entry_declaration=$(declare -p _AGENTGUARD_BASH_ENTRY 2>/dev/null) || :
        _agentguard_env_clean_declaration=$(declare -p _AGENTGUARD_ENV_CLEAN 2>/dev/null) || :
        if [ "$_agentguard_bash_entry_declaration" = \
          'declare -- _AGENTGUARD_BASH_ENTRY="agentguard-modern-bash-v2"' ] ||
          [ "$_agentguard_env_clean_declaration" = \
            'declare -- _AGENTGUARD_ENV_CLEAN="agentguard-environment-scrub-v2"' ]; then
          echo "@ENTRY_NAME@: exported functions appeared after the trusted environment scrub; refusing unguarded execution" >&2
          exit 2
        fi

        _agentguard_write_environment() {
          local _agentguard_name
          builtin compgen -e |
            while IFS= read -r _agentguard_name; do
              case "$_agentguard_name" in
                BASH_ENV | ENV | FUNCNEST | POSIXLY_CORRECT | BASH_COMPAT | \
                  BASH_XTRACEFD | AGENTGUARD_ENV_SCRUB_REEXEC | \
                  AGENTGUARD_HOOK_BASH_REEXEC | AGENTGUARD_CLASSIFY_COMMAND_REEXEC | \
                  _AGENTGUARD_BASH_ENTRY | _AGENTGUARD_ENV_CLEAN | \
                  _agentguard_saved_stdout_fd | _agentguard_saved_stdin_fd | \
                  _agentguard_stdin_state | _agentguard_complete | \
                  _agentguard_name | _agentguard_value | _agentguard_end | \
                  BASH | BASHPID | BASHOPTS | BASH_ARGC | BASH_ARGV | BASH_CMDS | \
                  BASH_COMMAND | BASH_EXECUTION_STRING | BASH_LINENO | \
                  BASH_LOADABLES_PATH | BASH_REMATCH | BASH_SOURCE | BASH_SUBSHELL | \
                  BASH_VERSINFO | BASH_VERSION | DIRSTACK | EUID | FUNCNAME | \
                  GROUPS | IFS | LINENO | OPTARG | OPTIND | PIPESTATUS | PPID | \
                  RANDOM | SECONDS | SHELLOPTS | SHLVL | UID | _)
                  continue
                  ;;
                "" | [!a-zA-Z_]* | *[!a-zA-Z0-9_]*) continue ;;
              esac
              printf '%s\0%s\0' "$_agentguard_name" "${!_agentguard_name}"
            done
          printf '\0%s\0' agentguard-environment-end-v2
        }

        if ! _agentguard_prepare_private_descriptors; then
          echo "@ENTRY_NAME@: cannot reserve private bootstrap descriptors; refusing unguarded execution" >&2
          exit 2
        fi
        # shellcheck disable=SC2016 # The clean Bash expands the receiver body.
        _agentguard_scrub_handshake=$(
          _agentguard_write_environment |
            /usr/bin/env -i /bin/bash --noprofile --norc -p -c '
        set +o posix
        unset FUNCNEST POSIXLY_CORRECT BASH_COMPAT
        export -n BASH_XTRACEFD 2>/dev/null || :
        _agentguard_saved_stdout_fd=$1
        _agentguard_stdin_state=$2
        _agentguard_saved_stdin_fd=$3
        shift 3
        _agentguard_complete=0
        while IFS= read -r -d "" _agentguard_name; do
          if [[ -z $_agentguard_name ]]; then
            IFS= read -r -d "" _agentguard_end || exit 2
            [[ $_agentguard_end == agentguard-environment-end-v2 ]] || exit 2
            _agentguard_complete=1
            break
          fi
          case "$_agentguard_name" in
            [a-zA-Z_]*) ;;
            *) exit 2 ;;
          esac
          [[ $_agentguard_name != *[!a-zA-Z0-9_]* ]] || exit 2
          IFS= read -r -d "" _agentguard_value || exit 2
          printf -v "$_agentguard_name" "%s" "$_agentguard_value" || exit 2
          export "$_agentguard_name" || exit 2
        done
        [[ $_agentguard_complete == 1 ]] || exit 2
        eval ": >&$_agentguard_saved_stdout_fd" || exit 2
        case "$_agentguard_stdin_state" in
          read) eval ": <&$_agentguard_saved_stdin_fd" || exit 2 ;;
          write) eval ": >&$_agentguard_saved_stdin_fd" || exit 2 ;;
          closed) ;;
          *) exit 2 ;;
        esac
        printf "%s\n" agentguard-environment-scrub-v2 || exit 2
        if [[ $_agentguard_stdin_state == read ]]; then
          eval "exec 1>&$_agentguard_saved_stdout_fd 0<&$_agentguard_saved_stdin_fd $_agentguard_saved_stdout_fd>&- $_agentguard_saved_stdin_fd<&-" || exit 2
        elif [[ $_agentguard_stdin_state == write ]]; then
          eval "exec 1>&$_agentguard_saved_stdout_fd 0>&$_agentguard_saved_stdin_fd $_agentguard_saved_stdout_fd>&- $_agentguard_saved_stdin_fd>&-" || exit 2
        else
          eval "exec 1>&$_agentguard_saved_stdout_fd 0<&- $_agentguard_saved_stdout_fd>&-" || exit 2
        fi
        unset _agentguard_saved_stdout_fd _agentguard_saved_stdin_fd \
          _agentguard_stdin_state _agentguard_complete _agentguard_name \
          _agentguard_value _agentguard_end
        unset _AGENTGUARD_BASH_ENTRY _AGENTGUARD_ENV_CLEAN
        _AGENTGUARD_ENV_CLEAN=agentguard-environment-scrub-v2
        source "$0" "$@"
      ' "$0" "$_agentguard_saved_stdout_fd" "$_agentguard_stdin_state" \
              "$_agentguard_saved_stdin_fd" "$@"
        )
        _agentguard_scrub_status=$?
        _agentguard_close_private_descriptors
        if [ "$_agentguard_scrub_handshake" != agentguard-environment-scrub-v2 ]; then
          echo "@ENTRY_NAME@: cannot rebuild a safe environment with /usr/bin/env and /bin/bash; refusing unguarded execution" >&2
          exit 2
        fi
        exit "$_agentguard_scrub_status"
        ;;
      *)
        echo "@ENTRY_NAME@: cannot inspect the environment with /usr/bin/awk; refusing unguarded execution" >&2
        exit 2
        ;;
    esac

    _agentguard_needs_modern_bash=1
    _agentguard_bash_major=${BASH_VERSION%%.*}
    _agentguard_bash_entry_declaration=$(declare -p _AGENTGUARD_BASH_ENTRY 2>/dev/null) || :
    case "$_agentguard_bash_major" in
      "" | *[!0-9]*) ;;
      *)
        if [ "$_agentguard_bash_major" -ge 4 ] &&
          [ "$_agentguard_bash_entry_declaration" = \
            'declare -- _AGENTGUARD_BASH_ENTRY="agentguard-modern-bash-v2"' ]; then
          if (eval 'declare -A _agentguard_probe=([identity]=bash); [[ ${_agentguard_probe[identity]} == bash ]]') \
            2>/dev/null; then
            _agentguard_needs_modern_bash=0
          fi
        fi
        ;;
    esac
    if [ "$_agentguard_needs_modern_bash" -eq 1 ]; then
      if ! _agentguard_prepare_private_descriptors; then
        echo "@ENTRY_NAME@: cannot reserve private bootstrap descriptors; refusing unguarded execution" >&2
        exit 2
      fi
      for _agentguard_bash in \
        /opt/homebrew/bin/bash /usr/local/bin/bash /bin/bash /usr/bin/bash; do
        [ -x "$_agentguard_bash" ] || continue
        _agentguard_bash_handshake=$(
          # shellcheck disable=SC2016 # The candidate Bash expands the entry body.
          /usr/bin/env -u FUNCNEST -u POSIXLY_CORRECT -u BASH_COMPAT \
            -u BASH_XTRACEFD -u _AGENTGUARD_BASH_ENTRY -u _AGENTGUARD_ENV_CLEAN \
            BASH_ENV='' ENV='' \
            "$_agentguard_bash" --noprofile --norc -p -c '
        set +o posix
        unset FUNCNEST POSIXLY_CORRECT BASH_COMPAT
        export -n BASH_XTRACEFD 2>/dev/null || :
        _agentguard_saved_stdout_fd=$1
        _agentguard_stdin_state=$2
        _agentguard_saved_stdin_fd=$3
        shift 3
        case "$-" in *p*) ;; *) exit 1 ;; esac
        [[ -n ${BASH_VERSION:-} ]] || exit 1
        case "${BASH_VERSINFO[0]:-}" in "" | *[!0-9]*) exit 1 ;; esac
        [[ ${BASH_VERSINFO[0]} -ge 4 ]] || exit 1
        declare -A _agentguard_probe=([identity]=bash) || exit 1
        [[ ${_agentguard_probe[identity]} == bash ]] || exit 1
        unset _agentguard_probe
        eval ": >&$_agentguard_saved_stdout_fd" || exit 1
        case "$_agentguard_stdin_state" in
          read) eval ": <&$_agentguard_saved_stdin_fd" || exit 1 ;;
          write) eval ": >&$_agentguard_saved_stdin_fd" || exit 1 ;;
          closed) ;;
          *) exit 1 ;;
        esac
        printf "%s\n" agentguard-modern-bash-v2 || exit 1
        if [[ $_agentguard_stdin_state == read ]]; then
          eval "exec 1>&$_agentguard_saved_stdout_fd 0<&$_agentguard_saved_stdin_fd $_agentguard_saved_stdout_fd>&- $_agentguard_saved_stdin_fd<&-" || exit 2
        elif [[ $_agentguard_stdin_state == write ]]; then
          eval "exec 1>&$_agentguard_saved_stdout_fd 0>&$_agentguard_saved_stdin_fd $_agentguard_saved_stdout_fd>&- $_agentguard_saved_stdin_fd>&-" || exit 2
        else
          eval "exec 1>&$_agentguard_saved_stdout_fd 0<&- $_agentguard_saved_stdout_fd>&-" || exit 2
        fi
        unset _agentguard_saved_stdout_fd _agentguard_saved_stdin_fd \
          _agentguard_stdin_state
        unset _AGENTGUARD_BASH_ENTRY _AGENTGUARD_ENV_CLEAN
        _AGENTGUARD_BASH_ENTRY=agentguard-modern-bash-v2
        source "$0" "$@"
      ' "$0" "$_agentguard_saved_stdout_fd" "$_agentguard_stdin_state" \
            "$_agentguard_saved_stdin_fd" "$@" </dev/null
        )
        _agentguard_bash_status=$?
        if [ "$_agentguard_bash_handshake" = agentguard-modern-bash-v2 ]; then
          _agentguard_close_private_descriptors
          exit "$_agentguard_bash_status"
        fi
      done
      _agentguard_close_private_descriptors
      echo "@ENTRY_NAME@: Bash 4 or newer is required; refusing unguarded execution" >&2
      exit 2
    fi

    unset BASH_ENV ENV FUNCNEST POSIXLY_CORRECT BASH_COMPAT \
      AGENTGUARD_HOOK_BASH_REEXEC AGENTGUARD_CLASSIFY_COMMAND_REEXEC \
      AGENTGUARD_ENV_SCRUB_REEXEC _AGENTGUARD_BASH_ENTRY \
      _AGENTGUARD_ENV_CLEAN
    unset _agentguard_private_fd_limit _agentguard_probe \
      _agentguard_environment_scan _agentguard_environment_scan_status \
      _agentguard_bash_entry_declaration _agentguard_env_clean_declaration \
      _agentguard_scrub_handshake _agentguard_scrub_status \
      _agentguard_needs_modern_bash _agentguard_bash_major \
      _agentguard_bash _agentguard_bash_handshake \
      _agentguard_bash_status _agentguard_complete _agentguard_name \
      _agentguard_value _agentguard_end
    unset -f _agentguard_fd_is_open _agentguard_reserve_fd \
      _agentguard_reserve_stdin _agentguard_prepare_private_descriptors \
      _agentguard_close_private_descriptors _agentguard_write_environment
    ;;
  *)
    /bin/echo "@ENTRY_NAME@: execute this file directly; explicit interpreter invocation bypasses the privileged bootstrap" >&2
    ;;
esac

case "$-" in
  *p*)
    set +p
    # @APPLICATION@
    ;;
  *)
    /bin/sh -c 'exit 2'
    ;;
esac
