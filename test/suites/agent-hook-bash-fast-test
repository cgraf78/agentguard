#!/usr/bin/env bash
# agent-hook-bash-fast-test — cheap pre-bash paths for common safe commands.

# shellcheck disable=SC1090,SC1091 # dynamic helper path resolved at runtime.
AGENTGUARD_TEST_HELPERS="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/agent-hook-helpers.sh"
. "$AGENTGUARD_TEST_HELPERS"

fast_install="$TEST_TMPDIR/fast-install"
classifier_marker="$TEST_TMPDIR/classifier-sourced"
_install_hook_fixture "$fast_install" agent-hook-pre-bash
classifier_module="$fast_install/lib/agentguard/hook-command-classifier.sh"
mv "$classifier_module" "$classifier_module.original"
{
  # shellcheck disable=SC2016 # The fixture module expands the marker path.
  printf '%s\n' 'printf "%s\n" sourced >"$AGENTGUARD_CLASSIFIER_MARKER"'
  cat "$classifier_module.original"
} >"$classifier_module"

_run_hook_with_classifier_marker() {
  local hook="$1"
  shift
  local input="${1:-}"
  HOOK_STDERR=""
  HOOK_EXIT=0
  local out_file err_file
  out_file=$(mktemp "$TEST_TMPDIR/out.XXXXXX")
  err_file=$(mktemp "$TEST_TMPDIR/err.XXXXXX")
  if [ -n "$input" ]; then
    printf '%s' "$input" |
      /usr/bin/env -i \
        HOME="$HOME" PATH="$PATH" \
        AGENTGUARD_SESSION_ID="$TEST_SID" \
        TMPDIR="$TEST_TMPDIR" \
        AGENTGUARD_NAME="agent" \
        AGENTGUARD_CLASSIFIER_MARKER="$classifier_marker" \
        CODEX_THREAD_ID="" \
        BASH_ENV='' ENV='' \
        "$hook" >"$out_file" 2>"$err_file" || HOOK_EXIT=$?
  else
    /usr/bin/env -i \
      HOME="$HOME" PATH="$PATH" \
      AGENTGUARD_SESSION_ID="$TEST_SID" \
      TMPDIR="$TEST_TMPDIR" \
      AGENTGUARD_NAME="agent" \
      AGENTGUARD_CLASSIFIER_MARKER="$classifier_marker" \
      CODEX_THREAD_ID="" \
      BASH_ENV='' ENV='' \
      "$hook" >"$out_file" 2>"$err_file" </dev/null || HOOK_EXIT=$?
  fi
  HOOK_STDERR=$(cat "$err_file")
  rm -f "$out_file" "$err_file"
}

echo ""
echo "=== pre-bash: git fast path ==="

rm -f "$classifier_marker"
_run_hook_with_classifier_marker "$fast_install/bin/agent-hook-pre-bash" \
  '{"tool_input":{"command":"git status --short"}}'
_assert_eq "git status --short: allowed" "0" "$HOOK_EXIT"
_assert_file_missing "git status --short: skips heavy classifier" "$classifier_marker"

rm -f "$classifier_marker"
_run_hook_with_classifier_marker "$fast_install/bin/agent-hook-pre-bash" \
  '{"tool_input":{"command":"git status --untracked-files=all"}}'
_assert_eq "git status --untracked-files=all outside protected bare repo: allowed" "0" "$HOOK_EXIT"
_assert_file_exists \
  "git status --untracked-files=all: delegates to dependency hook" \
  "$classifier_marker"
_assert_not_contains \
  "git status --untracked-files=all outside protected bare repo: no protected bare-Git scan block" \
  "protected bare-Git" \
  "$HOOK_STDERR"

_test_summary
