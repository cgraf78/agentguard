#!/usr/bin/env bash
# Verify that human-facing PATH commands have manual pages.

set -o pipefail
export NO_COLOR=1

AGENTGUARD_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
AGENTGUARD_REPO_ROOT="$(cd -- "$AGENTGUARD_TEST_DIR/.." && pwd -P)"

# shellcheck source=../helpers.sh
. "$AGENTGUARD_TEST_DIR/helpers.sh"

echo "=== agentguard: manpages ==="

while IFS= read -r command; do
  page="$AGENTGUARD_REPO_ROOT/man/man1/$command.1"
  _assert_file_exists "manpage exists: $command" "$page"
  content=$(cat "$page")
  _assert_contains "manpage NAME section: $command" ".SH NAME" "$content"
  _assert_contains "manpage names command: $command" "$command \\" "$content"
done < <(
  git -C "$AGENTGUARD_REPO_ROOT" ls-files -- 'bin/*' |
    xargs -n 1 basename |
    grep -v '^README.md$' |
    sort
)

echo ""
echo "=== agentguard: launcher security boundary documentation ==="

for relative_path in \
  README.md \
  lib/agentguard/README.md \
  man/man1/agent-hook-pre-bash.1 \
  man/man1/agentguard-classify-command.1; do
  content=$(cat "$AGENTGUARD_REPO_ROOT/$relative_path")
  normalized=$(printf '%s\n' "$content" | tr '\n' ' ' | tr -s ' ')
  _assert_contains "$relative_path: direct execution is the supported boundary" \
    "supported security boundary" "$normalized"
  _assert_contains "$relative_path: explicit interpreters are outside the boundary" \
    "outside this security boundary" "$normalized"
  _assert_contains "$relative_path: detectable rejection is best-effort" \
    "best-effort only" "$normalized"
done

_test_summary
