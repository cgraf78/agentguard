#!/usr/bin/env bash
# agent-hook-edit-test — edit hook behavior.

# shellcheck disable=SC2154 # shared apply_patch fixture is defined by agent-hook-helpers.sh.
# shellcheck disable=SC1090,SC1091 # dynamic helper path resolved at runtime.
AGENTGUARD_TEST_HELPERS="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/agent-hook-helpers.sh"
. "$AGENTGUARD_TEST_HELPERS"

# ---------------------------------------------------------------------------
# Tests: agent-hook-pre-edit — base guards
# ---------------------------------------------------------------------------

echo ""
echo "=== pre-edit: base guards ==="

PRE_EDIT="$BIN_DIR/agent-hook-pre-edit"
PROMPT_SUBMIT="$BIN_DIR/agent-hook-prompt-submit"

# Normal file → passes
_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/home/user/src/main.cpp"}}'
_assert_eq "normal file: exit 0" "0" "$HOOK_EXIT"

# No file_path → passes
_run_hook "$PRE_EDIT" '{"tool_input":{}}'
_assert_eq "no file_path: exit 0" "0" "$HOOK_EXIT"

_run_hook "$PRE_EDIT" "$_apply_patch_json"
_assert_eq "apply_patch paths: exit 0" "0" "$HOOK_EXIT"

echo "=== pre-edit: code comment reminder ==="

_reset_state
_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/home/user/src/main.cpp"}}'
_assert_eq "code reminder: exit 0" "0" "$HOOK_EXIT"
_assert_contains "code reminder: points to design source rule" "AGENTS.md > Design Principles" "$HOOK_STDERR"
_assert_contains "code reminder: points to workflow source rule" "Engineering Workflow" "$HOOK_STDERR"
_assert_contains "code reminder: mentions ownership" "Keep ownership clear" "$HOOK_STDERR"
_assert_contains "code reminder: mentions small cycles" "small code/test/review/fix cycles" "$HOOK_STDERR"
_assert_contains "code reminder: mentions why comments" "Add comments for why" "$HOOK_STDERR"
_assert_contains "code reminder: names useful comment context" "invariants, tradeoffs, edge cases, and cross-system assumptions" "$HOOK_STDERR"
_assert_contains "code reminder: avoids obvious comments" "avoid comments that restate obvious code" "$HOOK_STDERR"
_assert_contains "code reminder: emits hook context" "additionalContext" "$HOOK_STDOUT"
_assert_contains "code reminder: context includes steer" "Code edit:" "$HOOK_STDOUT"

_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/home/user/src/other.cpp"}}'
_assert_eq "code reminder once per prompt: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "code reminder once per prompt: no repeated stderr" "Code edit:" "$HOOK_STDERR"
_assert_not_contains "code reminder once per prompt: no repeated context" "Code edit:" "$HOOK_STDOUT"

_run_hook "$PROMPT_SUBMIT" '{"prompt":"please continue"}'
_assert_eq "prompt submit resets code reminder: exit 0" "0" "$HOOK_EXIT"

_run_hook "$PRE_EDIT" "$_apply_patch_json"
_assert_eq "apply_patch reminder after prompt reset: exit 0" "0" "$HOOK_EXIT"
_assert_contains "apply_patch reminder after prompt reset: code paths trigger reminder" "Code edit:" "$HOOK_STDERR"
_assert_contains "apply_patch reminder after prompt reset: context includes steer" "Code edit:" "$HOOK_STDOUT"

_reset_state
_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/home/user/notes/readme.txt"}}'
_assert_eq "non-code reminder: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "non-code reminder: no comment reminder" "Code edit:" "$HOOK_STDERR"
_assert_not_contains "non-code reminder: no context reminder" "Code edit:" "$HOOK_STDOUT"

_reset_state
_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/home/user/secrets.yaml"}}'
_assert_eq "blocked code reminder: exits blocked" "2" "$HOOK_EXIT"
_assert_contains "blocked code reminder: secrets guard blocks" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "blocked code reminder: no reminder on blocked edit" "Code edit:" "$HOOK_STDERR"
_assert_not_contains "blocked code reminder: no context on blocked edit" "Code edit:" "$HOOK_STDOUT"

_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/home/user/src/main.py"}}'
_assert_eq "blocked code reminder: later allowed edit exits 0" "0" "$HOOK_EXIT"
_assert_contains "blocked code reminder: later allowed edit still reminds" "Code edit:" "$HOOK_STDERR"

local_block_home=$(_tmpdir)
_install_hook_fixture "$local_block_home" agent-hook-pre-edit
cat >"$local_block_home/bin/agent-hook-pre-edit-work" <<'MOCK'
_hook_block "local readonly guard"
MOCK

_reset_state
_run_hook "$local_block_home/bin/agent-hook-pre-edit" '{"tool_input":{"file_path":"/home/user/src/local.py"}}'
_assert_eq "local blocked code reminder: exits blocked" "2" "$HOOK_EXIT"
_assert_contains "local blocked code reminder: local guard blocks" "local readonly guard" "$HOOK_STDERR"
_assert_not_contains "local blocked code reminder: no reminder on blocked edit" "Code edit:" "$HOOK_STDERR"
_assert_not_contains "local blocked code reminder: no context on blocked edit" "Code edit:" "$HOOK_STDOUT"

_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/home/user/src/after-local.py"}}'
_assert_eq "local blocked code reminder: later allowed edit exits 0" "0" "$HOOK_EXIT"
_assert_contains "local blocked code reminder: later allowed edit still reminds" "Code edit:" "$HOOK_STDERR"

_reset_state
codex_out=$(mktemp "$TEST_TMPDIR/codex-pre-edit-out.XXXXXX")
codex_err=$(mktemp "$TEST_TMPDIR/codex-pre-edit-err.XXXXXX")
HOOK_EXIT=0
printf '%s' "$_apply_patch_json" |
  AGENTGUARD_SESSION_ID="$TEST_SID" \
    TMPDIR="$TEST_TMPDIR" \
    AGENTGUARD_NAME="codex" \
    CODEX_THREAD_ID="" \
    "$PRE_EDIT" >"$codex_out" 2>"$codex_err" || HOOK_EXIT=$?
_assert_eq "codex apply_patch reminder: exit 0" "0" "$HOOK_EXIT"
_assert_contains "codex apply_patch reminder: stderr includes steer" "Code edit:" "$(cat "$codex_err")"
if jq -e '(has("suppressOutput") | not) and (.hookSpecificOutput.additionalContext | contains("Code edit:"))' "$codex_out" >/dev/null 2>&1; then
  _pass "codex apply_patch reminder: context includes steer"
else
  _fail "codex apply_patch reminder: context includes steer (got '$(cat "$codex_out")')"
fi

# ---------------------------------------------------------------------------
# Tests: agent-hook-pre-edit + post-edit — edit churn detection
# ---------------------------------------------------------------------------

echo ""
echo "=== edit churn: tracking and guard ==="

POST_EDIT="$BIN_DIR/agent-hook-post-edit"

_churn_file() {
  AGENTGUARD_SESSION_ID="$TEST_SID" \
    AGENTGUARD_NAME="agent" \
    TMPDIR="$TEST_TMPDIR" \
    CODEX_THREAD_ID="" \
    bash -c 'source "$1"; _hook_edit_churn_file "$2"' _ "$HELPERS" "$1"
}

_churn_key() { basename "$(_churn_file "$1")"; }

_reset_state

# Counter increments on each edit
_run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/tmp/test/foo.py"}}'
_assert_file_content "churn: first edit count is 1" "1" \
  "$(_churn_file "/tmp/test/foo.py")"

_run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/tmp/test/foo.py"}}'
_assert_file_content "churn: second edit count is 2" "2" \
  "$(_churn_file "/tmp/test/foo.py")"

# Independent files tracked separately
_run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/tmp/test/bar.py"}}'
_assert_file_content "churn: bar.py count is 1" "1" \
  "$(_churn_file "/tmp/test/bar.py")"
_assert_file_content "churn: foo.py still 2" "2" \
  "$(_churn_file "/tmp/test/foo.py")"

# apply_patch payloads can touch multiple files; post-edit should track each.
_run_hook "$POST_EDIT" "$_apply_patch_json"
_assert_file_content "churn: apply_patch a.py count is 1" "1" \
  "$(_churn_file "/tmp/test/a.py")"
_assert_file_content "churn: apply_patch b.py count is 1" "1" \
  "$(_churn_file "/tmp/test/b.py")"
_assert_file_content "churn: apply_patch c.py count is 1" "1" \
  "$(_churn_file "/tmp/test/c.py")"

echo "=== edit churn: below threshold ==="

_reset_state
for _ in 1 2 3 4; do
  _run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/tmp/test/f.py"}}'
done

# 4 edits done → pre-edit should pass clean
_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/tmp/test/f.py"}}'
_assert_eq "churn 4: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "churn 4: no WARNING" "WARNING" "$HOOK_STDERR"

echo "=== edit churn: warn at threshold ==="

_run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/tmp/test/f.py"}}'

# 5 edits done → pre-edit should warn on 6th attempt
_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/tmp/test/f.py"}}'
_assert_eq "churn 5: exit 0 (warn doesn't block)" "0" "$HOOK_EXIT"
_assert_contains "churn 5: WARNING in stderr" "WARNING" "$HOOK_STDERR"
_assert_contains "churn 5: mentions count" "5 times" "$HOOK_STDERR"
_assert_contains "churn 5: shows filename" "f.py" "$HOOK_STDERR"
_assert_contains "churn 5: shows bypass" "AGENTGUARD_EDIT_CHURN_BYPASS=1" "$HOOK_STDERR"

echo "=== edit churn: block at threshold ==="

for _ in 6 7 8 9 10; do
  _run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/tmp/test/f.py"}}'
done

# 10 edits done → pre-edit should block
_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/tmp/test/f.py"}}'
_assert_eq "churn 10: exit 2 (blocked)" "2" "$HOOK_EXIT"
_assert_contains "churn 10: BLOCKED in stderr" "BLOCKED" "$HOOK_STDERR"
_assert_contains "churn 10: mentions count" "10 times" "$HOOK_STDERR"
_assert_contains "churn 10: shows filename" "f.py" "$HOOK_STDERR"
_assert_contains "churn 10: shows bypass" "AGENTGUARD_EDIT_CHURN_BYPASS=1" "$HOOK_STDERR"

echo "=== edit churn: bypass ==="

HOOK_EXIT=0
out_file=$(mktemp "$TEST_TMPDIR/out.XXXXXX")
err_file=$(mktemp "$TEST_TMPDIR/err.XXXXXX")
printf '%s' '{"tool_input":{"file_path":"/tmp/test/f.py"}}' |
  AGENTGUARD_SESSION_ID="$TEST_SID" \
    AGENTGUARD_NAME="agent" \
    TMPDIR="$TEST_TMPDIR" \
    CODEX_THREAD_ID="" \
    AGENTGUARD_EDIT_CHURN_BYPASS=1 \
    "$PRE_EDIT" >"$out_file" 2>"$err_file" || HOOK_EXIT=$?
HOOK_STDERR=$(cat "$err_file")
rm -f "$out_file" "$err_file"
_assert_eq "churn bypass: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "churn bypass: no warning" "WARNING" "$HOOK_STDERR"
_assert_not_contains "churn bypass: no block" "BLOCKED" "$HOOK_STDERR"

HOOK_EXIT=0
out_file=$(mktemp "$TEST_TMPDIR/out.XXXXXX")
err_file=$(mktemp "$TEST_TMPDIR/err.XXXXXX")
printf '%s' '{"tool_input":{"file_path":"/tmp/test/f.py"}}' |
  AGENTGUARD_SESSION_ID="$TEST_SID" \
    AGENTGUARD_NAME="agent" \
    TMPDIR="$TEST_TMPDIR" \
    CODEX_THREAD_ID="" \
    AGENTGUARD_EDIT_CHURN_BYPASS=true \
    "$PRE_EDIT" >"$out_file" 2>"$err_file" || HOOK_EXIT=$?
HOOK_STDERR=$(cat "$err_file")
rm -f "$out_file" "$err_file"
_assert_eq "churn bypass true: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "churn bypass true: no warning" "WARNING" "$HOOK_STDERR"
_assert_not_contains "churn bypass true: no block" "BLOCKED" "$HOOK_STDERR"

echo "=== edit churn: first edit has no warning ==="

_reset_state
_run_hook "$PRE_EDIT" '{"tool_input":{"file_path":"/tmp/test/never-edited.py"}}'
_assert_eq "churn first: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "churn first: no WARNING" "WARNING" "$HOOK_STDERR"
_assert_not_contains "churn first: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

echo "=== edit churn: custom thresholds ==="

_reset_state
for _ in 1 2 3; do
  _run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/tmp/test/g.py"}}'
done

# Custom warn=3 via env
HOOK_EXIT=0
out_file=$(mktemp "$TEST_TMPDIR/out.XXXXXX")
err_file=$(mktemp "$TEST_TMPDIR/err.XXXXXX")
printf '%s' '{"tool_input":{"file_path":"/tmp/test/g.py"}}' |
  AGENTGUARD_SESSION_ID="$TEST_SID" \
    AGENTGUARD_NAME="agent" \
    TMPDIR="$TEST_TMPDIR" \
    CODEX_THREAD_ID="" \
    AGENTGUARD_EDIT_CHURN_WARN=3 AGENTGUARD_EDIT_CHURN_BLOCK=6 \
    "$PRE_EDIT" >"$out_file" 2>"$err_file" || HOOK_EXIT=$?
HOOK_STDERR=$(cat "$err_file")
rm -f "$out_file" "$err_file"
_assert_eq "churn custom warn=3: exit 0" "0" "$HOOK_EXIT"
_assert_contains "churn custom warn=3: WARNING" "WARNING" "$HOOK_STDERR"

# Custom block=6 via env
for _ in 4 5 6; do
  _run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/tmp/test/g.py"}}'
done
HOOK_EXIT=0
out_file=$(mktemp "$TEST_TMPDIR/out.XXXXXX")
err_file=$(mktemp "$TEST_TMPDIR/err.XXXXXX")
printf '%s' '{"tool_input":{"file_path":"/tmp/test/g.py"}}' |
  AGENTGUARD_SESSION_ID="$TEST_SID" \
    AGENTGUARD_NAME="agent" \
    TMPDIR="$TEST_TMPDIR" \
    CODEX_THREAD_ID="" \
    AGENTGUARD_EDIT_CHURN_WARN=3 AGENTGUARD_EDIT_CHURN_BLOCK=6 \
    "$PRE_EDIT" >"$out_file" 2>"$err_file" || HOOK_EXIT=$?
HOOK_STDERR=$(cat "$err_file")
rm -f "$out_file" "$err_file"
_assert_eq "churn custom block=6: exit 2" "2" "$HOOK_EXIT"
_assert_contains "churn custom block=6: BLOCKED" "BLOCKED" "$HOOK_STDERR"

echo "=== edit churn: empty file_path ==="

_reset_state

# Post-edit with no file_path should not create churn state
_run_hook "$POST_EDIT" '{"tool_input":{}}'
churn_dir="$TEST_TMPDIR/hook-state/$TEST_SID/edit-churn"
if [ -d "$churn_dir" ] && [ -n "$(ls -A "$churn_dir" 2>/dev/null)" ]; then
  _fail "churn empty AGENTGUARD_EDIT_FILE: no churn files should exist"
else
  _pass "churn empty AGENTGUARD_EDIT_FILE: no churn files created"
fi

echo "=== edit churn: path hashing ==="

_reset_state

# Collision resistance: paths that differ only by slash vs underscore
_run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/a/b_c"}}'
_run_hook "$POST_EDIT" '{"tool_input":{"file_path":"/a_b/c"}}'
key_a=$(_churn_key "/a/b_c")
key_b=$(_churn_key "/a_b/c")
if [[ "$key_a" != "$key_b" ]]; then
  _pass "churn hash: /a/b_c and /a_b/c produce different keys"
else
  _fail "churn hash: /a/b_c and /a_b/c collided (key=$key_a)"
fi
_assert_file_content "churn hash: /a/b_c count is 1" "1" \
  "$(_churn_file "/a/b_c")"
_assert_file_content "churn hash: /a_b/c count is 1" "1" \
  "$(_churn_file "/a_b/c")"

# Long paths don't exceed NAME_MAX
long_path="/$(printf '%0.sdir/' {1..60})/file.cpp"
_run_hook "$POST_EDIT" "{\"tool_input\":{\"file_path\":\"$long_path\"}}"
_assert_file_exists "churn hash: long path file created" \
  "$(_churn_file "$long_path")"

echo "=== post-edit: formats files through sley ==="

_copy_hook_sley_home() {
  local home="$1"

  _install_hook_fixture "$home/.local" agent-hook-post-edit
  cat >"$home/.local/bin/sley" <<'MOCK'
#!/usr/bin/env bash
[ "$1" = hook ] || exit 2
shift
case "$1" in
  format-file)
    shift
    printf 'format:%s:%s:%s\n' "${SLEY_CALLER:-}" "$PWD" "$1" >>"$SLEY_HOOK_LOG"
    ;;
  lint-file)
    shift
    printf 'lint:%s:%s\n' "${SLEY_CALLER:-}" "$*" >>"$SLEY_HOOK_LOG"
    ;;
  *)
    exit 2
    ;;
esac
MOCK
  chmod +x "$home/.local/bin/sley"
}

hook_home=$(_tmpdir)
_copy_hook_sley_home "$hook_home"
repo=$(_tmpdir)
(
  cd "$repo" || exit 1
  export GIT_CONFIG_GLOBAL="$repo/.gitconfig-test"
  : >"$GIT_CONFIG_GLOBAL"
  git init -q
  git config user.email test@test.local
  git config user.name "Test User"
  printf 'x = 1\n' >edited.py
  git add edited.py
  git commit -q -m "seed"
)
printf 'x = 2\n' >"$repo/edited.py"
export SLEY_HOOK_LOG="$repo/sley-hook.log"
mkdir -p "$hook_home/.config/sley/extensions.d"
cat >"$hook_home/.config/sley/extensions.d/80-test.sh" <<'MOCK'
sley_hook_format_file() {
  printf 'format:%s:%s:%s\n' "${SLEY_CALLER:-}" "${_REPO_TYPE:-}" "$1" >>"$SLEY_HOOK_LOG"
}
sley_hook_lint_file() {
  printf 'lint:%s:%s:%s\n' "${SLEY_CALLER:-}" "${_REPO_TYPE:-}" "$1" >>"$SLEY_HOOK_LOG"
}
MOCK

HOOK_EXIT=0
out_file=$(mktemp "$TEST_TMPDIR/out.XXXXXX")
err_file=$(mktemp "$TEST_TMPDIR/err.XXXXXX")
# Keep this fixture Claude-shaped even when the test runner itself is launched
# from Codex; otherwise inherited CODEX_THREAD_ID correctly wins detection.
printf '%s' "{\"tool_input\":{\"file_path\":\"$repo/edited.py\"}}" |
  HOME="$hook_home" \
    CLAUDE_CODE_CURRENT_SESSION_ID="$TEST_SID" \
    TMPDIR="$TEST_TMPDIR" \
    CODEX_INTERNAL_ORIGINATOR_OVERRIDE="" \
    CODEX_THREAD_ID="" \
    SLEY_HOOK_LOG="$SLEY_HOOK_LOG" \
    "$hook_home/.local/bin/agent-hook-post-edit" >"$out_file" 2>"$err_file" || HOOK_EXIT=$?
HOOK_STDERR=$(cat "$err_file")
rm -f "$out_file" "$err_file"
_assert_eq "post-edit sley delegation: exits 0" "0" "$HOOK_EXIT"
_assert_contains "post-edit sley delegation: formats through CLI from file repo" \
  "format:claude:$repo:$repo/edited.py" "$(cat "$SLEY_HOOK_LOG" 2>/dev/null)"
_assert_not_contains "post-edit sley delegation: defers lint to commit gate" \
  "lint:claude:$repo/edited.py" "$(cat "$SLEY_HOOK_LOG" 2>/dev/null)"
_assert_file_content "post-edit sley delegation: churn still tracked" "1" \
  "$(_churn_file "$repo/edited.py")"

echo "=== post-edit: missing sley is a broken install ==="

broken_home=$(_tmpdir)
_install_hook_fixture "$broken_home/.local" agent-hook-post-edit
repo=$(_tmpdir)
printf 'x = 1\n' >"$repo/edited.py"
HOOK_EXIT=0
out_file=$(mktemp "$TEST_TMPDIR/out.XXXXXX")
err_file=$(mktemp "$TEST_TMPDIR/err.XXXXXX")
printf '%s' "{\"tool_input\":{\"file_path\":\"$repo/edited.py\"}}" |
  HOME="$broken_home" \
    PATH="/usr/bin:/bin" \
    AGENTGUARD_SESSION_ID="$TEST_SID" \
    AGENTGUARD_NAME="agent" \
    TMPDIR="$TEST_TMPDIR" \
    "$broken_home/.local/bin/agent-hook-post-edit" >"$out_file" 2>"$err_file" || HOOK_EXIT=$?
HOOK_STDERR=$(cat "$err_file")
rm -f "$out_file" "$err_file"
_assert_exit "post-edit missing sley: exits broken" 2 "$HOOK_EXIT"
_assert_contains "post-edit missing sley: reports install issue" "sley command missing" "$HOOK_STDERR"

_test_summary
