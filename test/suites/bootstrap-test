#!/usr/bin/env python3
import signal
import subprocess
import sys


def reset_signals():
    for handled_signal in (signal.SIGHUP, signal.SIGINT, signal.SIGTERM):
        signal.signal(handled_signal, signal.SIG_DFL)


pid_file, command = sys.argv[1], sys.argv[2:]
process = subprocess.Popen(command, preexec_fn=reset_signals)
with open(pid_file, "w", encoding="ascii") as handle:
    handle.write(f"{process.pid}\n")
returncode = process.wait()
if returncode < 0:
    returncode = 128 - returncode
sys.exit(returncode)
PY
