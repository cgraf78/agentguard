#!/usr/bin/env bash
# Verify generated hook bootstraps stay synchronized and repair drift.

set -o pipefail
export NO_COLOR=1

AGENTGUARD_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
AGENTGUARD_ROOT="${AGENTGUARD_TEST_DIR%/test}"

# shellcheck source=../helpers.sh
. "$AGENTGUARD_TEST_DIR/helpers.sh"

echo "=== generated hook bootstrap ==="

fixture="$(_tmpdir)"
mkdir -p "$fixture/bin" "$fixture/support"
cp "$AGENTGUARD_ROOT/support/sync-hook-bootstrap" "$fixture/support/"
cp "$AGENTGUARD_ROOT/support/script-resolver.sh.template" "$fixture/support/"
cp "$AGENTGUARD_ROOT/bin/agent-hook-stop" "$fixture/bin/"
printf '%s\n' 'hook bin/agent-hook-stop' >"$fixture/support/launcher-bootstrap.manifest"

"$fixture/support/sync-hook-bootstrap" --check
_assert_exit "bootstrap sync: canonical hook passes drift check" 0 "$?"

drifted="$fixture/agent-hook-stop.drifted"
awk '
  { print }
  /^# Generated by support\/sync-hook-bootstrap/ { print "# deliberate test drift" }
' "$fixture/bin/agent-hook-stop" >"$drifted"
command cat "$drifted" >"$fixture/bin/agent-hook-stop"

"$fixture/support/sync-hook-bootstrap" --check >/dev/null 2>&1
_assert_exit "bootstrap sync: drift fails the check" 1 "$?"

"$fixture/support/sync-hook-bootstrap" >/dev/null
"$fixture/support/sync-hook-bootstrap" --check
_assert_exit "bootstrap sync: regeneration is idempotent" 0 "$?"
_assert_not_contains "bootstrap sync: regeneration removes drift" \
  "deliberate test drift" "$(cat "$fixture/bin/agent-hook-stop")"

awk '
  /^# BEGIN GENERATED LAUNCHER BOOTSTRAP$/ { removing = 1 }
  !removing { print }
  /^# END GENERATED LAUNCHER BOOTSTRAP$/ { removing = 0 }
' "$fixture/bin/agent-hook-stop" >"$drifted"
command cat "$drifted" >"$fixture/bin/agent-hook-stop"
"$fixture/support/sync-hook-bootstrap" --check >/dev/null 2>&1
_assert_exit "bootstrap sync: a missing block fails the check" 1 "$?"

cp "$AGENTGUARD_ROOT/bin/agent-hook-stop" "$fixture/bin/agent-hook-new-event"
"$fixture/support/sync-hook-bootstrap" --check >/dev/null 2>&1
_assert_exit "bootstrap sync: an unlisted base hook fails the check" 1 "$?"

_test_summary
