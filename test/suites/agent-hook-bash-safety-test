#!/usr/bin/env bash
# agent-hook-bash-safety-test — pre-bash rm safety guards.

# shellcheck disable=SC1090,SC1091 # dynamic helper path resolved at runtime.
AGENTGUARD_TEST_HELPERS="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/agent-hook-helpers.sh"
. "$AGENTGUARD_TEST_HELPERS"

# ---------------------------------------------------------------------------
# Tests: agent-hook-pre-bash — rm -rf guards
# ---------------------------------------------------------------------------

echo ""
echo "=== pre-bash: rm -rf guards ==="

# rm -rf / → blocked
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf /"}}'
_assert_eq "rm -rf /: exit 2" "2" "$HOOK_EXIT"
_assert_contains "rm -rf /: BLOCKED" "BLOCKED" "$HOOK_STDERR"

# rm -rf ~ → blocked
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf ~"}}'
_assert_eq "rm -rf ~: exit 2" "2" "$HOOK_EXIT"

# rm -rf $HOME → blocked (literal string, not expanded)
# shellcheck disable=SC2016
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf $HOME"}}'
_assert_eq "rm -rf \$HOME: exit 2" "2" "$HOOK_EXIT"

# rm -rf . → blocked (current directory)
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf ."}}'
_assert_eq "rm -rf .: exit 2" "2" "$HOOK_EXIT"

# rm -rf .. → blocked
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf .."}}'
_assert_eq "rm -rf ..: exit 2" "2" "$HOOK_EXIT"

# rm -rf / ; echo done → blocked (semicolon after dangerous path)
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf / ; echo done"}}'
_assert_eq "rm -rf / ;: exit 2" "2" "$HOOK_EXIT"
_assert_contains "rm -rf / ;: BLOCKED" "BLOCKED" "$HOOK_STDERR"

# rm -rf ~ | tee log → blocked (pipe after dangerous path)
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf ~ | tee log"}}'
_assert_eq "rm -rf ~ |: exit 2" "2" "$HOOK_EXIT"

# rm -rf / && ls → blocked (double-amp after dangerous path)
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf / && ls"}}'
_assert_eq "rm -rf / &&: exit 2" "2" "$HOOK_EXIT"

# rm -rf /some/path → warns but allows
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf /some/path"}}'
_assert_eq "rm -rf /some/path: exit 0" "0" "$HOOK_EXIT"
_assert_contains "rm -rf /some/path: warns" "WARNING" "$HOOK_STDERR"

# rm -r -f / → blocked
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -r -f /"}}'
_assert_eq "rm -r -f /: exit 2" "2" "$HOOK_EXIT"

# rm --recursive --force / → blocked
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm --recursive --force /"}}'
_assert_eq "rm --recursive --force /: exit 2" "2" "$HOOK_EXIT"

# r\m -rf / → blocked; Bash executes the escaped command word as `rm`.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"r\\m -rf /"}}'
_assert_eq "escaped rm -rf /: exit 2" "2" "$HOOK_EXIT"

# rm through privilege wrappers or shell control forms should still block.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"sudo rm -rf /"}}'
_assert_eq "sudo rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"sudo -Eu root rm -rf /"}}'
_assert_eq "sudo -Eu root rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"sudo -uroot rm -rf /"}}'
_assert_eq "sudo -uroot rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"doas rm -rf /"}}'
_assert_eq "doas rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"if rm -rf /; then echo done; fi"}}'
_assert_eq "if rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"! rm -rf /"}}'
_assert_eq "! rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"coproc rm -rf /"}}'
_assert_eq "coproc rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"while rm -rf /; do break; done"}}'
_assert_eq "while rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"case x in x) rm -rf /;; esac"}}'
_assert_eq "case arm rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"case x in y) echo no;; x) rm -rf /;; esac"}}'
_assert_eq "later case arm rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"f(){ rm -rf /; }; f"}}'
_assert_eq "called function body rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"f () { rm -rf /; }; f"}}'
_assert_eq "spaced function body rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"function f { rm -rf /; }; f"}}'
_assert_eq "function keyword body rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"function f() { rm -rf /; }; f"}}'
_assert_eq "function keyword parens body rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"env -S '\''rm -rf /'\''"}}'
_assert_eq "env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"bash -lc '\''rm -rf /'\''"}}'
_assert_eq "nested bash rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"bash -ec '\''rm -rf /'\''"}}'
_assert_eq "nested bash -ec rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"bash -elc '\''rm -rf /'\''"}}'
_assert_eq "nested bash -elc rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"eval '\''rm -rf /'\''"}}'
_assert_eq "eval rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"eval -- '\''rm -rf /'\''"}}'
_assert_eq "eval -- rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"exec rm -rf /"}}'
_assert_eq "exec rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"exec rm -rf /tmp/somewhere"}}'
_assert_eq "exec rm -rf /tmp/somewhere: exit 0" "0" "$HOOK_EXIT"
_assert_contains "exec rm -rf /tmp/somewhere: warns" "WARNING" "$HOOK_STDERR"

# Execution wrappers (nohup, nice, timeout) must not hide dangerous payloads.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"nohup rm -rf /"}}'
_assert_eq "nohup rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"timeout 5 rm -rf /"}}'
_assert_eq "timeout 5 rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"nice rm -rf /"}}'
_assert_eq "nice rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"nice -n 10 rm -rf /"}}'
_assert_eq "nice -n 10 rm -rf /: exit 2" "2" "$HOOK_EXIT"

# Safe payloads behind wrappers still pass.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"timeout 30 make -j8"}}'
_assert_eq "timeout 30 make: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "timeout 30 make: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

_cmd_sub_json=$(jq -nc --arg c 'echo $(rm -rf /)' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_cmd_sub_json"
_assert_eq "command substitution rm -rf /: exit 2" "2" "$HOOK_EXIT"

_quoted_cmd_sub_json=$(jq -nc --arg c 'echo "$(rm -rf /)"' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_quoted_cmd_sub_json"
_assert_eq "quoted command substitution rm -rf /: exit 2" "2" "$HOOK_EXIT"

_double_quoted_single_cmd_sub_json=$(jq -nc --arg c "echo \"'\$(rm -rf /)'\"" '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_double_quoted_single_cmd_sub_json"
_assert_eq "double-quoted command substitution with single quotes rm -rf /: exit 2" "2" "$HOOK_EXIT"

_backtick_json=$(jq -nc --arg c 'echo `rm -rf /`' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_backtick_json"
_assert_eq "backtick rm -rf /: exit 2" "2" "$HOOK_EXIT"

_quoted_backtick_json=$(jq -nc --arg c 'echo "`rm -rf /`"' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_quoted_backtick_json"
_assert_eq "quoted backtick rm -rf /: exit 2" "2" "$HOOK_EXIT"

_process_sub_json=$(jq -nc --arg c 'cat <(rm -rf /)' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_process_sub_json"
_assert_eq "process substitution rm -rf /: exit 2" "2" "$HOOK_EXIT"

_output_process_sub_json=$(jq -nc --arg c 'cat >(rm -rf /)' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_output_process_sub_json"
_assert_eq "output process substitution rm -rf /: exit 2" "2" "$HOOK_EXIT"

# Bare subshell groups: the tokenizer glues the closing `)` onto the final
# operand (`/)`, `~)`, `$HOME)`, `${HOME})`), which previously hid the
# catastrophic target and downgraded the block to a warning. All must block.
_subshell_root_json=$(jq -nc --arg c '(rm -rf /)' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_subshell_root_json"
_assert_eq "subshell rm -rf /: exit 2" "2" "$HOOK_EXIT"
_assert_contains "subshell rm -rf /: BLOCKED" "BLOCKED" "$HOOK_STDERR"

_subshell_tilde_json=$(jq -nc --arg c '(rm -rf ~)' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_subshell_tilde_json"
_assert_eq "subshell rm -rf ~: exit 2" "2" "$HOOK_EXIT"

_subshell_home_json=$(jq -nc --arg c '(rm -rf $HOME)' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_subshell_home_json"
_assert_eq "subshell rm -rf \$HOME: exit 2" "2" "$HOOK_EXIT"

_subshell_home_brace_json=$(jq -nc --arg c '(rm -rf ${HOME})' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_subshell_home_brace_json"
_assert_eq "subshell rm -rf \${HOME}: exit 2" "2" "$HOOK_EXIT"

_subshell_glob_json=$(jq -nc --arg c '(rm -rf /*)' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_subshell_glob_json"
_assert_eq "subshell rm -rf /*: exit 2" "2" "$HOOK_EXIT"

_nested_subshell_json=$(jq -nc --arg c '( (rm -rf /) )' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_nested_subshell_json"
_assert_eq "nested subshell rm -rf /: exit 2" "2" "$HOOK_EXIT"

# Stripping the stray closer must not over-block a non-catastrophic subshell
# target: balanced `${HOME}` is preserved, but `./build` is safe and only warns.
_subshell_safe_json=$(jq -nc --arg c '(rm -rf ./build)' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_subshell_safe_json"
_assert_eq "subshell rm -rf ./build: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "subshell rm -rf ./build: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

_heredoc_cmd_sub_json=$(jq -nc --arg c $'cat <<EOF\n$(rm -rf /)\nEOF' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_heredoc_cmd_sub_json"
_assert_eq "active heredoc command substitution rm -rf /: exit 2" "2" "$HOOK_EXIT"

_heredoc_multiline_cmd_sub_json=$(jq -nc --arg c $'cat <<EOF\n$(rm -rf \\\n/)\nEOF' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_heredoc_multiline_cmd_sub_json"
_assert_eq "active heredoc multiline command substitution rm -rf /: exit 2" "2" "$HOOK_EXIT"

_unterminated_heredoc_cmd_sub_json=$(jq -nc --arg c $'cat <<EOF\n$(rm -rf /)' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_unterminated_heredoc_cmd_sub_json"
_assert_eq "unterminated active heredoc command substitution rm -rf /: exit 2" "2" "$HOOK_EXIT"

_single_quoted_cmd_sub_json=$(jq -nc --arg c 'echo '\''$(rm -rf /)'\''' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_single_quoted_cmd_sub_json"
_assert_eq "single-quoted command substitution rm -rf /: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "single-quoted command substitution rm -rf /: no BLOCKED" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "single-quoted command substitution rm -rf /: no WARNING" "WARNING" "$HOOK_STDERR"

_single_quoted_process_sub_json=$(jq -nc --arg c 'echo '\''<(rm -rf /)'\''' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_single_quoted_process_sub_json"
_assert_eq "single-quoted process substitution rm -rf /: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "single-quoted process substitution rm -rf /: no BLOCKED" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "single-quoted process substitution rm -rf /: no WARNING" "WARNING" "$HOOK_STDERR"

_ansi_quote="'"
_ansi_rm_cmd="printf %s \$${_ansi_quote}\\${_ansi_quote}\$(rm -rf /)${_ansi_quote}"
_ansi_rm_json=$(jq -nc --arg c "$_ansi_rm_cmd" '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_ansi_rm_json"
_assert_eq "ANSI-C quoted command substitution rm -rf / text: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "ANSI-C quoted command substitution rm -rf / text: no BLOCKED" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "ANSI-C quoted command substitution rm -rf / text: no WARNING" "WARNING" "$HOOK_STDERR"

_quoted_heredoc_cmd_sub_json=$(jq -nc --arg c $'cat <<\'EOF\'\n$(rm -rf /)\nEOF' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_quoted_heredoc_cmd_sub_json"
_assert_eq "quoted heredoc command substitution rm -rf /: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "quoted heredoc command substitution rm -rf /: no BLOCKED" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "quoted heredoc command substitution rm -rf /: no WARNING" "WARNING" "$HOOK_STDERR"

_mixed_quoted_heredoc_json=$(jq -nc --arg c $'cat <<E"O"F\n$(rm -rf /)\nEOF' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_mixed_quoted_heredoc_json"
_assert_eq "mixed-quoted heredoc command substitution rm -rf /: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "mixed-quoted heredoc command substitution rm -rf /: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

_ansi_heredoc_then_rm_cmd="cat <<\$${_ansi_quote}EOF${_ansi_quote}"$'\nliteral\nEOF\nrm -rf /'
_ansi_heredoc_then_rm_json=$(jq -nc --arg c "$_ansi_heredoc_then_rm_cmd" '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_ansi_heredoc_then_rm_json"
_assert_eq "ANSI-C quoted heredoc delimiter then rm -rf /: exit 2" "2" "$HOOK_EXIT"

_multi_heredoc_cmd_sub_json=$(jq -nc --arg c $'cat <<\'SAFE\' <<RUN\nliteral\nSAFE\n$(rm -rf /)\nRUN' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_multi_heredoc_cmd_sub_json"
_assert_eq "second active heredoc command substitution rm -rf /: exit 2" "2" "$HOOK_EXIT"

_arithmetic_expansion_json=$(jq -nc --arg c 'echo $((rm -rf /))' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_arithmetic_expansion_json"
_assert_eq "arithmetic expansion text rm -rf /: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "arithmetic expansion text rm -rf /: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

_arithmetic_nested_cmd_sub_json=$(jq -nc --arg c 'echo $(( $(rm -rf /) + 1 ))' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_arithmetic_nested_cmd_sub_json"
_assert_eq "arithmetic nested command substitution rm -rf /: exit 2" "2" "$HOOK_EXIT"

_multiline_single_quote_json=$(jq -nc --arg c $'echo \'\nrm -rf /\n\'' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_multiline_single_quote_json"
_assert_eq "multiline single-quoted rm -rf / text: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "multiline single-quoted rm -rf / text: no BLOCKED" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "multiline single-quoted rm -rf / text: no WARNING" "WARNING" "$HOOK_STDERR"

_cmd_sub_heredoc_prose_json=$(jq -nc --arg c $'echo "$(cat <<EOF\nrm -rf /\nEOF\n)"' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_cmd_sub_heredoc_prose_json"
_assert_eq "command substitution heredoc prose rm -rf /: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "command substitution heredoc prose rm -rf /: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

_cmd_sub_active_heredoc_json=$(jq -nc --arg c $'echo "$(cat <<EOF\n$(rm -rf /)\nEOF\n)"' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_cmd_sub_active_heredoc_json"
_assert_eq "command substitution active heredoc rm -rf /: exit 2" "2" "$HOOK_EXIT"

# Prose or strings containing rm -rf should not trigger the rm guard.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"echo rm -rf /"}}'
_assert_eq "echo rm -rf /: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "echo rm -rf /: no BLOCKED" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "echo rm -rf /: no WARNING" "WARNING" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"printf '\''rm -rf /'\''"}}'
_assert_eq "printf rm -rf /: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "printf rm -rf /: no BLOCKED" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "printf rm -rf /: no WARNING" "WARNING" "$HOOK_STDERR"

# Non-rm command → passes clean
_run_hook "$PRE_BASH" '{"tool_input":{"command":"true"}}'
_assert_eq "true: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "true: no warning" "WARNING" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"ls -la"}}'
_assert_eq "ls: exit 0" "0" "$HOOK_EXIT"
_assert_not_contains "ls: no warning" "WARNING" "$HOOK_STDERR"

# Empty command → passes
_run_hook "$PRE_BASH" '{"tool_input":{"command":""}}'
_assert_eq "empty cmd: exit 0" "0" "$HOOK_EXIT"

# ---------------------------------------------------------------------------
# Tests: hardening red-team — bypass families closed by harden-command-guards
# ---------------------------------------------------------------------------

echo ""
echo "=== pre-bash: rm guard bypass hardening ==="

# Short and empty env-prefix assignments must not hide the real command word.
# A single-character or empty-value assignment is still an env prefix, so the
# guard has to skip past it and classify the rm that follows.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"A=1 rm -rf /"}}'
_assert_eq "single-char env assignment then rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"_=1 rm -rf /"}}'
_assert_eq "underscore env assignment then rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"x= rm -rf /"}}'
_assert_eq "empty-value env assignment then rm -rf /: exit 2" "2" "$HOOK_EXIT"

# A leading digit is not a valid identifier, so `1=2` is not an env prefix —
# the whole token is the command word and there is no dangerous rm to find.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"A=1 ls"}}'
_assert_eq "single-char env assignment then ls: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "single-char env assignment then ls: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# env --split-string variants: the payload can be attached to a short flag or
# clustered with other single-letter options. Each form still runs `rm -rf /`.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"env -S'\''rm -rf /'\''"}}'
_assert_eq "env -S attached value rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"env -iS '\''rm -rf /'\''"}}'
_assert_eq "env clustered -iS spaced value rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"env -iS'\''rm -rf /'\''"}}'
_assert_eq "env clustered -iS attached value rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"env --split-string='\''rm -rf /'\''"}}'
_assert_eq "env --split-string= attached value rm -rf /: exit 2" "2" "$HOOK_EXIT"

# xargs is an execution wrapper: the dangerous command follows it (optionally
# behind its own value-taking flags) and must still be classified.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"xargs rm -rf /"}}'
_assert_eq "xargs rm -rf /: exit 2" "2" "$HOOK_EXIT"

# `echo` (not `find`) leads here on purpose: piping through `find` would block
# via the find guard and mask whether the xargs wrapper itself was unwrapped.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"echo x | xargs -I{} rm -rf /"}}'
_assert_eq "xargs -I{} rm -rf /: exit 2" "2" "$HOOK_EXIT"

# xargs `-i` / `--replace` take an OPTIONAL attached argument and do NOT consume
# the next token, so the command word follows immediately. The wrapper-skip must
# not swallow `rm` as if `-i` were a value-taking option.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"xargs -i rm -rf /"}}'
_assert_eq "xargs -i rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"xargs --replace rm -rf /"}}'
_assert_eq "xargs --replace rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"xargs -n1 ls"}}'
_assert_eq "xargs -n1 ls: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "xargs -n1 ls: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"xargs -i ls {}"}}'
_assert_eq "xargs -i ls: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "xargs -i ls: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# A single transparent wrapper in front of `env --split-string` must not hide
# the payload: the env-split extractor skips privilege/execution wrappers before
# looking for the env that carries -S.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"sudo env -S '\''rm -rf /'\''"}}'
_assert_eq "sudo env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"nice env -S '\''rm -rf /'\''"}}'
_assert_eq "nice env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"timeout 5 env -S '\''rm -rf /'\''"}}'
_assert_eq "timeout 5 env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"xargs env -S '\''rm -rf /'\''"}}'
_assert_eq "xargs env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"sudo env -S '\''ls -la'\''"}}'
_assert_eq "sudo env -S ls -la: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "sudo env -S ls -la: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# env is itself a transparent command runner, so `env … env -S '<payload>'`
# reaches a second env whose split-string must still be extracted. The payload
# extractor re-resolves after each transparent layer.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"env env -S '\''rm -rf /'\''"}}'
_assert_eq "env env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"env A=1 env -S '\''rm -rf /'\''"}}'
_assert_eq "env assignment then env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

# `-u` takes a value: in `env -u env -S …` the inner `env` is the unset target,
# not a command, so -S is still this env's option and the payload still blocks.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"env -u env -S '\''rm -rf /'\''"}}'
_assert_eq "env -u env (value) -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"env env -S '\''ls -la'\''"}}'
_assert_eq "env env -S ls -la: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "env env -S ls -la: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# `env -S` must be decomposed wherever it runs on the line, not only as the first
# command: a `true;`/`&&`/`|`/`cd;` prefix must not hide the split-string payload.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"true; env -S '\''rm -rf /'\''"}}'
_assert_eq "non-leading env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"echo hi && env -S '\''rm -rf /'\''"}}'
_assert_eq "&&-chained env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"echo a | env -S '\''rm -rf /'\''"}}'
_assert_eq "piped env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

# Non-leading and wrapped at once: the per-fragment scan still reaches it.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"true; sudo env -S '\''rm -rf /'\''"}}'
_assert_eq "non-leading sudo env -S rm -rf /: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"true; env -S '\''ls -la'\''"}}'
_assert_eq "non-leading env -S ls -la: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "non-leading env -S ls -la: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# Dangerous rm targets expressed through brace expansion or path normalization
# resolve to / or $HOME and must block. _clean_command_word strips a trailing
# `}`, so the guard inspects the raw token to recognize ${HOME} forms.
# shellcheck disable=SC2016
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf ${HOME}"}}'
_assert_eq "rm -rf \${HOME}: exit 2" "2" "$HOOK_EXIT"

# shellcheck disable=SC2016
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf ${HOME}/"}}'
_assert_eq "rm -rf \${HOME}/: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf ~/.."}}'
_assert_eq "rm -rf ~/..: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf //"}}'
_assert_eq "rm -rf //: exit 2" "2" "$HOOK_EXIT"

# A trailing `/*` glob wipes everything directly under its parent, so a glob
# whose parent normalizes to $HOME's parent is as catastrophic as that parent.
# Use $HOME-relative forms so the assertion is portable (the actual home parent
# differs per platform, e.g. /home vs /Users).
# shellcheck disable=SC2016
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf ${HOME}/../*"}}'
_assert_eq "rm -rf \${HOME}/../*: exit 2" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf ~/../*"}}'
_assert_eq "rm -rf ~/../*: exit 2" "2" "$HOOK_EXIT"

# Safe globs under non-catastrophic directories must still pass.
# shellcheck disable=SC2016
_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf ${HOME}/.cache/*"}}'
_assert_eq "rm -rf \${HOME}/.cache/*: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "rm -rf \${HOME}/.cache/*: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"rm -rf /tmp/*"}}'
_assert_eq "rm -rf /tmp/*: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "rm -rf /tmp/*: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# Arithmetic left-shift uses `<<`, which must not be misparsed as a heredoc
# operator. If it were, the delimiter-seeking parser would swallow the rest of
# the script and hide the dangerous rm on the following line.
_arith_shift_heredoc_json=$(jq -nc --arg c $'echo $((1 << 2))\nrm -rf /' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_arith_shift_heredoc_json"
_assert_eq "arith shift then rm -rf /: exit 2" "2" "$HOOK_EXIT"

_arith_cmd_shift_heredoc_json=$(jq -nc --arg c $'((x << 3))\nrm -rf /' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_arith_cmd_shift_heredoc_json"
_assert_eq "arith command shift then rm -rf /: exit 2" "2" "$HOOK_EXIT"

# The shift expression on its own is benign and must not warn or block.
_arith_shift_only_json=$(jq -nc --arg c 'echo $((1 << 2))' '{"tool_input":{"command":$c}}')
_run_hook "$PRE_BASH" "$_arith_shift_only_json"
_assert_eq "arith shift only: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "arith shift only: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

