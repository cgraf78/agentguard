#!/usr/bin/env bash
# agent-hook-bash-gate-test — pre-bash commit guidance without readiness gates.

# shellcheck disable=SC1090,SC1091 # dynamic helper path resolved at runtime.
AGENTGUARD_TEST_HELPERS="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/agent-hook-helpers.sh"
. "$AGENTGUARD_TEST_HELPERS"

echo ""
echo "=== pre-bash: commit guidance without sley readiness gate ==="

mock_bin=$(_mock_bin)
cat >"$mock_bin/sley" <<'MOCK'
#!/usr/bin/env bash
printf 'mock-sley-was-called\n'
exit 1
MOCK
chmod +x "$mock_bin/sley"

_run_commit_hook() {
  local command="$1"
  _reset_state
  PATH="$mock_bin:$PATH" \
    _run_hook "$PRE_BASH" "$(jq -nc --arg c "$command" '{"tool_input":{"command":$c}}')"
}

_assert_no_sley_gate() {
  local label="$1"
  _assert_not_contains "$label: does not call sley" \
    "mock-sley-was-called" "$HOOK_STDERR"
  _assert_not_contains "$label: does not block on sley" \
    "sley ready" "$HOOK_STDERR"
}

_run_commit_hook "git commit -m foo"
_assert_eq "git commit: hook exits 0" "0" "$HOOK_EXIT"
_assert_no_sley_gate "git commit"
_assert_contains "git commit: review nudge still fires" \
  "/review or /simplify" "$HOOK_STDERR"
_assert_contains "git commit: review nudge references fresh-eyes rule" \
  "agent-rule-id: review-adversarial-fresh-eyes" "$HOOK_STDERR"
_assert_contains "git commit: public leak reminder still fires" \
  "private or environment-specific details" "$HOOK_STDERR"
_assert_contains "git commit: emits git commit rule id" \
  "agent-rule-id: git-commit-message-format" "$HOOK_STDERR"

_run_commit_hook "if git commit -m foo; then echo done; fi"
_assert_eq "if git commit: hook exits 0" "0" "$HOOK_EXIT"
_assert_no_sley_gate "if git commit"
_assert_contains "if git commit: review nudge still fires" \
  "/review or /simplify" "$HOOK_STDERR"
_assert_contains "if git commit: review nudge references fresh-eyes rule" \
  "agent-rule-id: review-adversarial-fresh-eyes" "$HOOK_STDERR"
_assert_contains "if git commit: public leak reminder still fires" \
  "private or environment-specific details" "$HOOK_STDERR"
_assert_contains "if git commit: emits git commit rule id" \
  "agent-rule-id: git-commit-message-format" "$HOOK_STDERR"

_run_commit_hook "echo git commit -m foo"
_assert_eq "echo git commit: not a commit command" "0" "$HOOK_EXIT"
_assert_no_sley_gate "echo git commit"
_assert_not_contains "echo git commit: no review nudge" \
  "/review or /simplify" "$HOOK_STDERR"
_assert_not_contains "echo git commit: no fresh-eyes rule nudge" \
  "agent-rule-id: review-adversarial-fresh-eyes" "$HOOK_STDERR"
_assert_not_contains "echo git commit: no public leak reminder" \
  "private or environment-specific details" "$HOOK_STDERR"
_assert_not_contains "echo git commit: no git commit rule id" \
  "agent-rule-id: git-commit-message-format" "$HOOK_STDERR"

_run_commit_hook "gh pr create --title \"Reference \`git commit\` rule ID from hooks\""
_assert_eq "backtick git commit in PR title: blocked" "2" "$HOOK_EXIT"
_assert_contains "backtick git commit in PR title: explains substitution risk" \
  "command substitution" "$HOOK_STDERR"

_run_commit_hook "title='Reference \`git commit\` rule ID from hooks'; printf '%s\n' \"\$title\""
_assert_eq "single-quoted git commit text: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "single-quoted git commit text: no substitution block" \
  "command substitution" "$HOOK_STDERR"

_run_commit_hook "sl amend"
_assert_eq "sl amend: hook exits 0" "0" "$HOOK_EXIT"
_assert_no_sley_gate "sl amend"
_assert_contains "sl amend: review nudge still fires" \
  "/review or /simplify" "$HOOK_STDERR"
_assert_contains "sl amend: review nudge references fresh-eyes rule" \
  "agent-rule-id: review-adversarial-fresh-eyes" "$HOOK_STDERR"
_assert_not_contains "sl amend: no git commit rule id" \
  "agent-rule-id: git-commit-message-format" "$HOOK_STDERR"

_run_commit_hook "sl absorb"
_assert_eq "sl absorb: hook exits 0" "0" "$HOOK_EXIT"
_assert_no_sley_gate "sl absorb"
_assert_contains "sl absorb: review nudge still fires" \
  "/review or /simplify" "$HOOK_STDERR"
_assert_contains "sl absorb: review nudge references fresh-eyes rule" \
  "agent-rule-id: review-adversarial-fresh-eyes" "$HOOK_STDERR"

_run_commit_hook "sl amend -m metadata"
_assert_eq "sl amend -m: metadata only" "0" "$HOOK_EXIT"
_assert_no_sley_gate "sl amend -m"
_assert_not_contains "sl amend -m: no review nudge" \
  "/review or /simplify" "$HOOK_STDERR"

_run_commit_hook "sl rebase --abort"
_assert_eq "sl rebase --abort: abort only" "0" "$HOOK_EXIT"
_assert_no_sley_gate "sl rebase --abort"
_assert_not_contains "sl rebase --abort: no review nudge" \
  "/review or /simplify" "$HOOK_STDERR"

_test_summary
