# ---------------------------------------------------------------------------
# Tests: broad process kill guard
# ---------------------------------------------------------------------------

echo ""
echo "=== pre-bash: broad kill guard ==="

_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill 1"}}'
_assert_eq "kill 1: blocked" "2" "$HOOK_EXIT"
_assert_contains "kill 1: BLOCKED msg" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill -9 1"}}'
_assert_eq "kill -9 1: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill -KILL 1"}}'
_assert_eq "kill -KILL 1: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill -s KILL 1"}}'
_assert_eq "kill -s KILL 1: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"killall vim"}}'
_assert_eq "killall: warns" "0" "$HOOK_EXIT"
_assert_contains "killall: WARNING msg" "WARNING" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"pkill -f myprocess"}}'
_assert_eq "pkill: warns" "0" "$HOOK_EXIT"
_assert_contains "pkill: WARNING msg" "WARNING" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill -9 1234"}}'
_assert_eq "kill -9 PID: warns" "0" "$HOOK_EXIT"
_assert_contains "kill -9 PID: WARNING msg" "WARNING" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill -s KILL 5678"}}'
_assert_eq "kill -s KILL PID: warns" "0" "$HOOK_EXIT"

# Normal kill (SIGTERM) of a non-init process is fine
_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill 1234"}}'
_assert_eq "kill SIGTERM PID: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "kill SIGTERM PID: no BLOCKED" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "kill SIGTERM PID: no WARNING" "WARNING" "$HOOK_STDERR"

# echo of kill is prose
_run_hook "$PRE_BASH" '{"tool_input":{"command":"echo kill 1"}}'
_assert_eq "echo kill 1: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "echo kill 1: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# A `--` end-of-options separator must not let PID 1 slip past the broad-kill
# guard: the guard consumes `--` and keeps scanning the operands for `1`.
_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill -- 1"}}'
_assert_eq "kill -- 1: blocked" "2" "$HOOK_EXIT"
_assert_contains "kill -- 1: BLOCKED msg" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill -9 -- 1"}}'
_assert_eq "kill -9 -- 1: blocked" "2" "$HOOK_EXIT"

# `--` before a normal PID is still allowed (SIGTERM to a non-init process).
_run_hook "$PRE_BASH" '{"tool_input":{"command":"kill -- 1234"}}'
_assert_eq "kill -- 1234: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "kill -- 1234: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# ---------------------------------------------------------------------------
# Tests: chmod overreach guard
# ---------------------------------------------------------------------------

echo ""
echo "=== pre-bash: chmod overreach guard ==="

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod 777 script.sh"}}'
_assert_eq "chmod 777: blocked" "2" "$HOOK_EXIT"
_assert_contains "chmod 777: BLOCKED msg" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod 0777 script.sh"}}'
_assert_eq "chmod 0777: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod -R 777 /tmp/deploy"}}'
_assert_eq "chmod -R 777: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod 666 file.txt"}}'
_assert_eq "chmod 666: warns" "0" "$HOOK_EXIT"
_assert_contains "chmod 666: WARNING msg" "WARNING" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod o+w file.txt"}}'
_assert_eq "chmod o+w: warns" "0" "$HOOK_EXIT"
_assert_contains "chmod o+w: WARNING msg" "WARNING" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod a+w dir/"}}'
_assert_eq "chmod a+w: warns" "0" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod a=rwx script.sh"}}'
_assert_eq "chmod a=rwx: warns" "0" "$HOOK_EXIT"

# Safe modes are fine
_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod 755 script.sh"}}'
_assert_eq "chmod 755: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "chmod 755: no BLOCKED" "BLOCKED" "$HOOK_STDERR"
_assert_not_contains "chmod 755: no WARNING" "WARNING" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod 644 file.txt"}}'
_assert_eq "chmod 644: allowed" "0" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod u+x script.sh"}}'
_assert_eq "chmod u+x: allowed" "0" "$HOOK_EXIT"

# u=rwx and g=rwx grant no world-write access — must not warn
_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod u=rwx script.sh"}}'
_assert_eq "chmod u=rwx: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "chmod u=rwx: no WARNING" "WARNING" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"chmod g=rwx script.sh"}}'
_assert_eq "chmod g=rwx: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "chmod g=rwx: no WARNING" "WARNING" "$HOOK_STDERR"

# echo of chmod is prose
_run_hook "$PRE_BASH" '{"tool_input":{"command":"echo chmod 777 foo"}}'
_assert_eq "echo chmod 777: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "echo chmod 777: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

