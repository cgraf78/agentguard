#!/usr/bin/env bash
# agent-hook-bash-guards-test — pre-bash destructive-operation guards:
#   sudo, git reset --hard, git clean -f, git push --force,
#   TTY-required commands, broad kills, chmod overreach.
# pre-edit secrets file guard.

# shellcheck disable=SC1090,SC1091 # dynamic helper path resolved at runtime.
AGENTGUARD_TEST_HELPERS="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/agent-hook-helpers.sh"
. "$AGENTGUARD_TEST_HELPERS"

# ---------------------------------------------------------------------------
# Tests: sudo guard
# ---------------------------------------------------------------------------

echo ""
echo "=== pre-bash: sudo guard ==="

_run_hook "$PRE_BASH" '{"tool_input":{"command":"sudo apt install vim"}}'
_assert_eq "sudo: blocked" "2" "$HOOK_EXIT"
_assert_contains "sudo: BLOCKED msg" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"/usr/bin/sudo rm -rf /var/cache"}}'
_assert_eq "path-qualified sudo: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"bash -c '\''sudo chmod 755 /etc'\''"}}'
_assert_eq "nested shell sudo: blocked" "2" "$HOOK_EXIT"

# echo of sudo is prose, not execution
_run_hook "$PRE_BASH" '{"tool_input":{"command":"echo sudo apt install vim"}}'
_assert_eq "echo sudo: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "echo sudo: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# ---------------------------------------------------------------------------
# Tests: git reset --hard guard
# ---------------------------------------------------------------------------

echo ""
echo "=== pre-bash: git reset --hard guard ==="

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git reset --hard"}}'
_assert_eq "git reset --hard: blocked" "2" "$HOOK_EXIT"
_assert_contains "git reset --hard: BLOCKED msg" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git reset --hard HEAD~1"}}'
_assert_eq "git reset --hard HEAD~1: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git -C /tmp/repo reset --hard origin/main"}}'
_assert_eq "git -C reset --hard: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" "$(jq -nc --arg c 'bash -c "git reset --hard"' '{"tool_input":{"command":$c}}')"
_assert_eq "nested bash git reset --hard: blocked" "2" "$HOOK_EXIT"

# git reset without --hard is fine
_run_hook "$PRE_BASH" '{"tool_input":{"command":"git reset HEAD file.txt"}}'
_assert_eq "git reset (no --hard): allowed" "0" "$HOOK_EXIT"
_assert_not_contains "git reset (no --hard): no BLOCKED" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git reset --soft HEAD~1"}}'
_assert_eq "git reset --soft: allowed" "0" "$HOOK_EXIT"

# echo of git reset --hard is prose
_run_hook "$PRE_BASH" '{"tool_input":{"command":"echo git reset --hard"}}'
_assert_eq "echo git reset --hard: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "echo git reset --hard: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# exec/timeout/nohup/nice wrappers must not bypass guards
_run_hook "$PRE_BASH" '{"tool_input":{"command":"exec git reset --hard"}}'
_assert_eq "exec git reset --hard: blocked" "2" "$HOOK_EXIT"
_assert_contains "exec git reset --hard: BLOCKED msg" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"timeout 5 git reset --hard"}}'
_assert_eq "timeout git reset --hard: blocked" "2" "$HOOK_EXIT"
_assert_contains "timeout git reset --hard: BLOCKED msg" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"nohup git reset --hard"}}'
_assert_eq "nohup git reset --hard: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"nice -n 5 git reset --hard"}}'
_assert_eq "nice git reset --hard: blocked" "2" "$HOOK_EXIT"

# ---------------------------------------------------------------------------
# Tests: git clean -f guard
# ---------------------------------------------------------------------------

echo ""
echo "=== pre-bash: git clean -f guard ==="

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git clean -f"}}'
_assert_eq "git clean -f: blocked" "2" "$HOOK_EXIT"
_assert_contains "git clean -f: BLOCKED msg" "BLOCKED" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git clean -fd"}}'
_assert_eq "git clean -fd: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git clean -df"}}'
_assert_eq "git clean -df: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git clean -fdx"}}'
_assert_eq "git clean -fdx: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git clean --force"}}'
_assert_eq "git clean --force: blocked" "2" "$HOOK_EXIT"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git -C /tmp/repo clean -fd"}}'
_assert_eq "git -C clean -fd: blocked" "2" "$HOOK_EXIT"

# dry-run does not trigger our guard (tests use /tmp path to avoid the
# separate protected bare-Git-repo guard that fires when CWD is $HOME)
_run_hook "$PRE_BASH" '{"tool_input":{"command":"git -C /tmp clean -n"}}'
_assert_not_contains "git clean -n: no clean-force BLOCKED" "git clean -f deletes" "$HOOK_STDERR"

_run_hook "$PRE_BASH" '{"tool_input":{"command":"git -C /tmp clean --dry-run"}}'
_assert_not_contains "git clean --dry-run: no clean-force BLOCKED" "git clean -f deletes" "$HOOK_STDERR"

# echo of git clean -f is prose
_run_hook "$PRE_BASH" '{"tool_input":{"command":"echo git clean -fd"}}'
_assert_eq "echo git clean -fd: allowed" "0" "$HOOK_EXIT"
_assert_not_contains "echo git clean -fd: no BLOCKED" "BLOCKED" "$HOOK_STDERR"

# exec wrapper must not bypass git clean guard
_run_hook "$PRE_BASH" '{"tool_input":{"command":"exec git clean -fd"}}'
_assert_eq "exec git clean -fd: blocked" "2" "$HOOK_EXIT"
_assert_contains "exec git clean -fd: BLOCKED msg" "BLOCKED" "$HOOK_STDERR"

