#!/usr/bin/env bash
# agent-hook-helpers-test — shared helper behavior.

# shellcheck disable=SC2016,SC2030,SC2031,SC2154 # child snippets, subshell fixtures, shared fixture vars.
# shellcheck disable=SC1090 # tests intentionally source hook helpers through a fixture variable.
# shellcheck disable=SC1091 # protected bare-Git test helper lives under HOME.
AGENTGUARD_TEST_HELPERS="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/agent-hook-helpers.sh"
. "$AGENTGUARD_TEST_HELPERS"

unset AGENTGUARD_SESSION_ID

# ---------------------------------------------------------------------------
# Tests: agentguard.sh — public API wrappers
# ---------------------------------------------------------------------------

echo "=== agentguard: public API ==="

AGENTGUARD_API="$AGENTGUARD_ROOT/lib/agentguard/agentguard.sh"

api_agent_name=$(
  AGENTGUARD_NAME=codex bash -c '
    source "$1"
    agentguard_agent_name
  ' _ "$AGENTGUARD_API"
)
_assert_eq "public api: agent name wrapper delegates detection" \
  "codex" "$api_agent_name"

AGENTGUARD_NAME=codex bash -c '
  source "$1"
  agentguard_is_session
' _ "$AGENTGUARD_API"
_assert_exit "public api: agent session wrapper detects env" 0 "$?"

# ---------------------------------------------------------------------------
# Tests: hook-helpers.sh — shared helper functions
# ---------------------------------------------------------------------------

echo "=== hook-helpers: block/warn/context ==="

HELPERS="$AGENTGUARD_ROOT/lib/agentguard/hook-helpers.sh"

# _hook_block sets flag and prints to stderr
(
  source "$HELPERS"
  _hook_block "test reason"
  [ "$_HOOK_BLOCKED" = 1 ] && echo "PASS" || echo "FAIL"
) 2>/dev/null | grep -q PASS
_assert_eq "hook_block: sets flag" "0" "$?"

(
  source "$HELPERS"
  _hook_block "test reason" 2>&1
) | grep -q 'BLOCKED: test reason'
_assert_eq "hook_block: prints BLOCKED to stderr" "0" "$?"

# _hook_warn prints WARNING to stderr, does not block
(
  source "$HELPERS"
  _hook_warn "be careful"
  [ -z "$_HOOK_BLOCKED" ] && echo "PASS" || echo "FAIL"
) 2>/dev/null | grep -q PASS
_assert_eq "hook_warn: does not set block flag" "0" "$?"

(
  source "$HELPERS"
  _hook_warn "be careful" 2>&1
) | grep -q 'WARNING: be careful'
_assert_eq "hook_warn: prints WARNING to stderr" "0" "$?"

warn_ctx=$(
  source "$HELPERS"
  _hook_warn "be careful" 2>/dev/null
  printf '%s' "$_HOOK_CTX"
)
_assert_eq "hook_warn: adds hook context" "be careful" "$warn_ctx"

# _hook_remind prints REMINDER to stderr, does not block
(
  source "$HELPERS"
  _hook_remind "check something"
  [ -z "$_HOOK_BLOCKED" ] && echo "PASS" || echo "FAIL"
) 2>/dev/null | grep -q PASS
_assert_eq "hook_remind: does not set block flag" "0" "$?"

(
  source "$HELPERS"
  _hook_remind "check something" 2>&1
) | grep -q 'REMINDER: check something'
_assert_eq "hook_remind: prints REMINDER to stderr" "0" "$?"

remind_ctx=$(
  source "$HELPERS"
  _hook_remind "check something" 2>/dev/null
  printf '%s' "$_HOOK_CTX"
)
_assert_eq "hook_remind: adds hook context" "check something" "$remind_ctx"

# _hook_context accumulates lines with newline separation
ctx_out=$(
  source "$HELPERS"
  _hook_context "line one"
  _hook_context "line two"
  printf '%s' "$_HOOK_CTX"
)
_assert_contains "hook_context: has first line" "line one" "$ctx_out"
_assert_contains "hook_context: has second line" "line two" "$ctx_out"
line_count=$(printf '%s\n' "$ctx_out" | wc -l)
_assert_eq "hook_context: two lines" "2" "$(echo "$line_count" | tr -d ' ')"

path_home=$(_tmpdir)
mkdir -p "$path_home/.local/bin"
cat >"$path_home/.local/bin/sley" <<'MOCK'
#!/usr/bin/env bash
:
MOCK
chmod +x "$path_home/.local/bin/sley"
test_bash=$(command -v bash)
path_probe=$(
  # shellcheck disable=SC2016 # inner bash intentionally expands probe vars.
  HOME="$path_home" PATH='' "$test_bash" -c '
    source "$1"
    case "$PATH" in
      "" | :* | *::* | *:) printf "path_has_empty=yes\n" ;;
      *) printf "path_has_empty=no\n" ;;
    esac
    printf "sley=%s\n" "$(command -v sley 2>/dev/null || true)"
    printf "dirname=%s\n" "$(command -v dirname 2>/dev/null || true)"
  ' _ "$HELPERS"
)
_assert_contains "hook PATH fallback: empty PATH has no cwd component" \
  "path_has_empty=no" "$path_probe"
_assert_contains "hook PATH fallback: empty PATH exposes local bin" \
  "sley=$path_home/.local/bin/sley" "$path_probe"
_assert_contains "hook PATH fallback: empty PATH keeps system tools" \
  "dirname=/usr/bin/dirname" "$path_probe"

# _HOOK_STATE_DIR computed at source time from neutral agent session id.
# shellcheck disable=SC2034  # env vars consumed by sourced helpers, not direct use
(
  AGENTGUARD_SESSION_ID="neutral-session"
  CODEX_THREAD_ID="codex-thread-123"
  CLAUDE_CODE_CURRENT_SESSION_ID="test123"
  TMPDIR="/tmp/test"
  source "$HELPERS"
  if [ "$_HOOK_STATE_DIR" = "/tmp/test/hook-state/neutral-session" ]; then
    echo "PASS"
  else
    echo "FAIL: $_HOOK_STATE_DIR"
  fi
) | grep -q PASS
_assert_eq "state_dir: neutral session id wins" "0" "$?"

# _HOOK_STATE_DIR computed at source time (Claude env vars)
# shellcheck disable=SC2034  # env vars consumed by sourced helpers, not direct use
(
  unset CODEX_THREAD_ID 2>/dev/null
  CLAUDE_CODE_CURRENT_SESSION_ID="test123"
  TMPDIR="/tmp/test"
  source "$HELPERS"
  [ "$_HOOK_STATE_DIR" = "/tmp/test/hook-state/test123" ] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: claude env vars" "0" "$?"

# _HOOK_STATE_DIR uses CODEX_THREAD_ID before Claude-compatible vars. Current
# Codex hook environments expose this as the stable session key, and matching
# the detector priority keeps state isolation consistent with emitted schema.
# shellcheck disable=SC2034  # env vars consumed by sourced helpers, not direct use
(
  CODEX_THREAD_ID="codex-thread-123"
  CLAUDE_CODE_CURRENT_SESSION_ID="test123"
  TMPDIR="/tmp/test"
  source "$HELPERS"
  [ "$_HOOK_STATE_DIR" = "/tmp/test/hook-state/codex-thread-123" ] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: codex thread id wins over claude env" "0" "$?"

# Codex hook subprocesses do not always inherit a runtime session id. Managed
# Codex hooks use AGENTGUARD_NAME, and the helper falls back to the long-lived
# Codex process so session-local Hive Memory state does not reset on every hook.
(
  env -u CODEX_THREAD_ID -u CLAUDE_CODE_CURRENT_SESSION_ID \
    AGENTGUARD_NAME="codex" \
    AGENTGUARD_PROCESS_DETECT=0 \
    TMPDIR="/tmp/codex-process-test" \
    bash -c '
    source "$1"
    [[ "$_HOOK_STATE_DIR" == "/tmp/codex-process-test/hook-state/codex-"* ]] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
  ' _ "$HELPERS"
) | grep -q PASS
_assert_eq "state_dir: codex process key fallback" "0" "$?"

# If the hook runner provides a JSON session id, prefer that precise key over
# the Codex process fallback.
(
  unset CODEX_THREAD_ID CLAUDE_CODE_CURRENT_SESSION_ID 2>/dev/null
  AGENTGUARD_NAME="codex"
  TMPDIR="/tmp/codex-json-test"
  _HOOK_INPUT='{"session_id":"codex-json-session"}'
  source "$HELPERS"
  [ "$_HOOK_STATE_DIR" = "/tmp/codex-json-test/hook-state/codex-json-session" ] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: codex JSON session id wins over process fallback" "0" "$?"

# _HOOK_STATE_DIR uses TMPDIR for the tmp root
# shellcheck disable=SC2034  # env vars consumed by sourced helpers, not direct use
(
  unset AGENTGUARD_NAME CODEX_INTERNAL_ORIGINATOR_OVERRIDE CODEX_THREAD_ID \
    CLAUDE_CODE_CURRENT_SESSION_ID 2>/dev/null
  TMPDIR="/tmp/custom"
  source "$HELPERS"
  [[ "$_HOOK_STATE_DIR" == "/tmp/custom/hook-state/"* ]] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: TMPDIR fallback" "0" "$?"

# _HOOK_STATE_DIR falls back to /tmp and PID when no env vars set
(
  unset AGENTGUARD_NAME CODEX_INTERNAL_ORIGINATOR_OVERRIDE CODEX_THREAD_ID \
    CLAUDE_CODE_CURRENT_SESSION_ID TMPDIR 2>/dev/null
  source "$HELPERS"
  [[ "$_HOOK_STATE_DIR" == "/tmp/hook-state/"* ]] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: falls back to /tmp and PID" "0" "$?"

# _HOOK_STATE_DIR uses gemini-$PPID when GEMINI_PROJECT_DIR is set
# shellcheck disable=SC2034  # env vars consumed by sourced helpers, not direct use
(
  unset AGENTGUARD_NAME CODEX_INTERNAL_ORIGINATOR_OVERRIDE CODEX_THREAD_ID \
    CLAUDE_CODE_CURRENT_SESSION_ID 2>/dev/null
  GEMINI_PROJECT_DIR="/tmp/project"
  TMPDIR="/tmp/gemtest"
  source "$HELPERS"
  [[ "$_HOOK_STATE_DIR" == "/tmp/gemtest/hook-state/gemini-"* ]] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: gemini uses PPID-based key" "0" "$?"

# Claude session ID wins over Gemini for state dir.
# shellcheck disable=SC2034  # env vars consumed by sourced helpers, not direct use
(
  unset CODEX_THREAD_ID 2>/dev/null
  CLAUDE_CODE_CURRENT_SESSION_ID="test123"
  TMPDIR="/tmp/test"
  GEMINI_PROJECT_DIR="/tmp/project"
  source "$HELPERS"
  [ "$_HOOK_STATE_DIR" = "/tmp/test/hook-state/test123" ] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: claude session ID wins over gemini" "0" "$?"

# _HOOK_STATE_DIR can be refreshed from hook JSON session_id when no agent env
# vars provide a stable session key.
(
  unset CODEX_THREAD_ID CLAUDE_CODE_CURRENT_SESSION_ID GEMINI_PROJECT_DIR 2>/dev/null
  TMPDIR="/tmp/json-session-test"
  source "$HELPERS"
  _HOOK_INPUT='{"session_id":"json-session-123"}'
  _hook_refresh_state_dir
  [ "$_HOOK_STATE_DIR" = "/tmp/json-session-test/hook-state/json-session-123" ] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: refresh uses input session_id" "0" "$?"

# Existing env-derived keys continue to win over JSON session_id.
# shellcheck disable=SC2034  # env vars consumed by sourced helpers, not direct use
(
  unset CODEX_THREAD_ID 2>/dev/null
  CLAUDE_CODE_CURRENT_SESSION_ID="test123"
  TMPDIR="/tmp/test"
  source "$HELPERS"
  _HOOK_INPUT='{"session_id":"json-session-123"}'
  _hook_refresh_state_dir
  [ "$_HOOK_STATE_DIR" = "/tmp/test/hook-state/test123" ] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: claude env wins over input session_id" "0" "$?"

# Parsing command JSON refreshes state from session_id for agents without env
# session IDs.
(
  unset CODEX_THREAD_ID CLAUDE_CODE_CURRENT_SESSION_ID GEMINI_PROJECT_DIR 2>/dev/null
  TMPDIR="/tmp/parse-session-test"
  source "$HELPERS"
  _HOOK_INPUT='{"session_id":"parse-session-123","tool_input":{"command":"echo ok"}}'
  _hook_parse_command 2>/dev/null </dev/null
  [ "$_HOOK_STATE_DIR" = "/tmp/parse-session-test/hook-state/parse-session-123" ] && echo "PASS" || echo "FAIL: $_HOOK_STATE_DIR"
) | grep -q PASS
_assert_eq "state_dir: parse_command refreshes input session_id" "0" "$?"

# Codex API exec_command payloads use tool_input.cmd instead of command.
(
  unset CODEX_THREAD_ID CLAUDE_CODE_CURRENT_SESSION_ID GEMINI_PROJECT_DIR 2>/dev/null
  source "$HELPERS"
  _HOOK_INPUT='{"tool_input":{"cmd":"echo ok"}}'
  _hook_parse_command 2>/dev/null </dev/null
  [ "$AGENTGUARD_CMD_TRIMMED" = "echo ok" ] && echo "PASS" || echo "FAIL: $AGENTGUARD_CMD_TRIMMED"
) | grep -q PASS
_assert_eq "parse_command: accepts cmd fallback" "0" "$?"

(
  unset CODEX_THREAD_ID CLAUDE_CODE_CURRENT_SESSION_ID GEMINI_PROJECT_DIR 2>/dev/null
  source "$HELPERS"
  _HOOK_INPUT="$_apply_patch_json"
  _hook_parse_edit_files 2>/dev/null </dev/null
  want=$(printf '%s\n' "/tmp/test/a.py" "/tmp/test/b.py" "/tmp/test/c.py")
  if [ "$AGENTGUARD_EDIT_FILES" = "$want" ] && [ "$AGENTGUARD_EDIT_FILE" = "/tmp/test/a.py" ]; then
    echo "PASS"
  else
    printf 'FAIL: files=%s fp=%s\n' "$AGENTGUARD_EDIT_FILES" "$AGENTGUARD_EDIT_FILE"
  fi
) | grep -q PASS
_assert_eq "parse_edit_files: extracts apply_patch paths in order" "0" "$?"

_apply_patch_object_json=$(jq -n --arg patch \
  "$(printf '%s\n' \
    "*** Begin Patch" \
    "*** Delete File: /tmp/test/remove.py" \
    "*** End Patch")" \
  '{"tool_input":{"patch":$patch}}')
(
  unset CODEX_THREAD_ID CLAUDE_CODE_CURRENT_SESSION_ID GEMINI_PROJECT_DIR 2>/dev/null
  source "$HELPERS"
  _HOOK_INPUT="$_apply_patch_object_json"
  _hook_parse_edit_files 2>/dev/null </dev/null
  [ "$AGENTGUARD_EDIT_FILES" = "/tmp/test/remove.py" ] && echo "PASS" || echo "FAIL: $AGENTGUARD_EDIT_FILES"
) | grep -q PASS
_assert_eq "parse_edit_files: extracts object patch paths" "0" "$?"

# ---------------------------------------------------------------------------
