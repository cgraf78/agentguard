# Tests: hook-helpers.sh — _hook_parse_command / AGENTGUARD_CMD_LINE1
# ---------------------------------------------------------------------------

echo ""
echo "=== hook-helpers: _hook_parse_command ==="

# _hook_parse_command uses _HOOK_INPUT=$(cat) on first call.  Set
# _HOOK_INPUT directly to avoid running the function in a pipe subshell
# (which would discard the exported vars).

# Single-line command: AGENTGUARD_CMD_LINE1 equals AGENTGUARD_CMD_TRIMMED
(
  source "$HELPERS"
  _HOOK_INPUT='{"tool_input":{"command":"ls -la /tmp"}}'
  _hook_parse_command 2>/dev/null </dev/null
  [ "$AGENTGUARD_CMD_LINE1" = "$AGENTGUARD_CMD_TRIMMED" ] && echo "PASS" || echo "FAIL: AGENTGUARD_CMD_LINE1='$AGENTGUARD_CMD_LINE1' AGENTGUARD_CMD_TRIMMED='$AGENTGUARD_CMD_TRIMMED'"
) | grep -q PASS
_assert_eq "parse_command: single-line AGENTGUARD_CMD_LINE1 == AGENTGUARD_CMD_TRIMMED" "0" "$?"

# Multi-line command: AGENTGUARD_CMD_LINE1 is only the first line
# shellcheck disable=SC2016
multiline_json=$(jq -nc --arg c "$(printf '%s\n%s\n%s' 'git commit -m "$(cat <<'\''EOF'\''' 'Fix git push handling' 'EOF)"')" '{"tool_input":{"command":$c}}')
(
  source "$HELPERS"
  _HOOK_INPUT="$multiline_json"
  _hook_parse_command 2>/dev/null </dev/null
  line_count=$(printf '%s\n' "$AGENTGUARD_CMD_LINE1" | wc -l | tr -d ' ')
  [ "$line_count" = "1" ] && echo "PASS" || echo "FAIL: $line_count lines"
) | grep -q PASS
_assert_eq "parse_command: multi-line AGENTGUARD_CMD_LINE1 is one line" "0" "$?"

# Multi-line: AGENTGUARD_CMD_LINE1 contains the command, not the body
(
  source "$HELPERS"
  _HOOK_INPUT="$multiline_json"
  _hook_parse_command 2>/dev/null </dev/null
  echo "$AGENTGUARD_CMD_LINE1" | grep -q 'git commit' && echo "PASS" || echo "FAIL: $AGENTGUARD_CMD_LINE1"
) | grep -q PASS
_assert_eq "parse_command: AGENTGUARD_CMD_LINE1 has the command" "0" "$?"

# Multi-line: AGENTGUARD_CMD_LINE1 does NOT contain heredoc body content
(
  source "$HELPERS"
  _HOOK_INPUT="$multiline_json"
  _hook_parse_command 2>/dev/null </dev/null
  echo "$AGENTGUARD_CMD_LINE1" | grep -q 'git push' && echo "FAIL" || echo "PASS"
) | grep -q PASS
_assert_eq "parse_command: AGENTGUARD_CMD_LINE1 excludes heredoc body" "0" "$?"

# Multi-line: AGENTGUARD_CMD_TRIMMED still has the full content
(
  source "$HELPERS"
  _HOOK_INPUT="$multiline_json"
  _hook_parse_command 2>/dev/null </dev/null
  trimmed_lines=$(printf '%s\n' "$AGENTGUARD_CMD_TRIMMED" | wc -l | tr -d ' ')
  [ "$trimmed_lines" -gt 1 ] && echo "PASS" || echo "FAIL: $trimmed_lines lines"
) | grep -q PASS
_assert_eq "parse_command: AGENTGUARD_CMD_TRIMMED retains all lines" "0" "$?"

# Leading whitespace stripped from AGENTGUARD_CMD_LINE1
(
  source "$HELPERS"
  _HOOK_INPUT='{"tool_input":{"command":"  ls -la"}}'
  _hook_parse_command 2>/dev/null </dev/null
  [ "$AGENTGUARD_CMD_LINE1" = "ls -la" ] && echo "PASS" || echo "FAIL: '$AGENTGUARD_CMD_LINE1'"
) | grep -q PASS
_assert_eq "parse_command: AGENTGUARD_CMD_LINE1 strips leading whitespace" "0" "$?"

