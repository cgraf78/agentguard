echo ""
echo "=== hook-helpers: Hive Memory integration ==="

HM_MOCK_ROOT=$(_tmpdir)
HM_HOME="$HM_MOCK_ROOT/home"
HM_BIN="$HM_MOCK_ROOT/bin"
HM_TMP="$HM_MOCK_ROOT/tmp"
HM_LOG="$HM_MOCK_ROOT/hm.log"
mkdir -p "$HM_HOME/.config/hive-memory" "$HM_BIN" "$HM_TMP"
touch "$HM_HOME/.config/hive-memory/config.toml"
cat >"$HM_BIN/hm" <<'SCRIPT'
#!/usr/bin/env bash
{
  printf 'args=%s\n' "$*"
  printf 'agent=%s\n' "${HIVE_MEMORY_AGENT_ID:-}"
  printf 'session=%s\n' "${HIVE_MEMORY_SESSION_ID:-}"
  printf 'project=%s\n' "${HIVE_MEMORY_PROJECT:-}"
  printf 'project_infer=%s\n' "${HIVE_MEMORY_PROJECT_INFER:-}"
  printf 'active=%s\n' "${AGENTGUARD_HIVE_MEMORY_HOOK_ACTIVE:-}"
} >>"$HM_LOG"

case "${HM_MODE:-empty}" in
  response)
    printf '%s\n' '{"warnings":["low confidence"],"actions":[{"kind":"inject_context","body":"memory ctx"},{"kind":"remind","body":"write reminder"}]}'
    ;;
  fail)
    printf 'backend offline\n' >&2
    exit 42
    ;;
  *)
    printf '%s\n' '{"warnings":[],"actions":[]}'
    ;;
esac
SCRIPT
chmod +x "$HM_BIN/hm"

hm_prompt_err="$HM_MOCK_ROOT/prompt.err"
hm_prompt_out=$(
  HOME="$HM_HOME" \
    PATH="$HM_BIN:$PATH" \
    TMPDIR="$HM_TMP" \
    HM_LOG="$HM_LOG" \
    HM_MODE=response \
    AGENTGUARD_HIVE_MEMORY_HOOKS=1 \
    AGENTGUARD_NAME=codex \
    CODEX_THREAD_ID="hm-session" \
    bash -c '
      source "$1"
      _HOOK_INPUT='\''{"prompt":"remember this","tool_input":{"file_path":"/tmp/project/src/main.rs"}}'\''
      _hook_hm_prompt_submit
      printf "%s" "$_HOOK_CTX"
    ' _ "$HELPERS" 2>"$hm_prompt_err"
)
hm_prompt_log=$(cat "$HM_LOG")
_assert_contains "hm hook: prompt-submit command includes project and text" \
  "args=hook prompt-submit --project /tmp/project/src/main.rs --json --text remember this" "$hm_prompt_log"
_assert_contains "hm hook: passes agent identity" "agent=codex" "$hm_prompt_log"
_assert_contains "hm hook: passes session identity" "session=hm-session" "$hm_prompt_log"
_assert_contains "hm hook: passes active project env" "project=/tmp/project/src/main.rs" "$hm_prompt_log"
_assert_contains "hm hook: marks subprocess hook-active" "active=1" "$hm_prompt_log"
_assert_contains "hm hook: injects context action" "memory ctx" "$hm_prompt_out"
_assert_contains "hm hook: injects reminder action" "write reminder" "$hm_prompt_out"
_assert_contains "hm hook: surfaces response warnings" \
  "WARNING: Hive Memory: low confidence" "$(cat "$hm_prompt_err")"

prompt_input_preserved=$(
