_run_dense_descriptor_entry() {
  local kind="$1" highest="$2"
  local output="$TEST_TMPDIR/dense-$kind-$highest.output"
  local error="$TEST_TMPDIR/dense-$kind-$highest.error"
  local high_writes="$TEST_TMPDIR/dense-$kind-$highest.high"
