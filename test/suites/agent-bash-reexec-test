_run_control_entry() {
  local kind="$1" mode="$2" name="$3" value="$4"
  local output="$TEST_TMPDIR/control-$kind-$mode-$name.output"
  local error="$TEST_TMPDIR/control-$kind-$mode-$name.error"
  local rc
  set +e
  if [[ $kind == hook ]]; then
    if [[ $mode == dirty ]]; then
      printf '%s' '{"tool_input":{"command":"rm -rf /"}}' |
        env -i HOME="$HOME" PATH="$PATH" "$name=$value" \
          'BASH_FUNC_agentguard_control%%=() { :; }' \
          "$control_hook" >"$output" 2>"$error"
    else
      printf '%s' '{"tool_input":{"command":"rm -rf /"}}' |
        env -i HOME="$HOME" PATH="$PATH" "$name=$value" \
          "$control_hook" >"$output" 2>"$error"
    fi
  elif [[ $mode == dirty ]]; then
    env -i HOME="$HOME" PATH="$PATH" "$name=$value" \
      'BASH_FUNC_agentguard_control%%=() { :; }' \
      "$control_classifier" --json -- 'printf ok' >"$output" 2>"$error"
  else
    env -i HOME="$HOME" PATH="$PATH" "$name=$value" \
      "$control_classifier" --json -- 'printf ok' >"$output" 2>"$error"
  fi
  rc=$?
  set -e

  if [[ $kind == hook ]]; then
    _assert_eq "$kind $mode $name=$value: dangerous command remains blocked" "2" "$rc"
    _assert_contains "$kind $mode $name=$value: block protocol remains intact" \
      "BLOCKED: rm -rf" "$(cat "$error")"
    _assert_not_contains "$kind $mode $name=$value: control state does not reach extensions" \
      "shell-control variable leaked" "$(cat "$error")"
    _assert_not_contains "$kind $mode $name=$value: bootstrap state does not reach extensions" \
      "bootstrap state leaked" "$(cat "$error")"
    _assert_not_contains "$kind $mode $name=$value: bootstrap functions do not reach extensions" \
      "bootstrap function leaked" "$(cat "$error")"
  else
    _assert_eq "$kind $mode $name=$value: classification succeeds" "0" "$rc"
    _assert_eq "$kind $mode $name=$value: classification remains exact" "printf" \
      "$(jq -r '.commands[0].basename' "$output" 2>/dev/null)"
    _assert_not_contains "$kind $mode $name=$value: control state does not reach classifier" \
      "shell-control variable leaked" "$(cat "$error")"
    _assert_not_contains "$kind $mode $name=$value: bootstrap state does not reach classifier" \
      "bootstrap state leaked" "$(cat "$error")"
    _assert_not_contains "$kind $mode $name=$value: bootstrap functions do not reach classifier" \
      "bootstrap function leaked" "$(cat "$error")"
  fi
}

