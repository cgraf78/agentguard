        AGENTGUARD_DENSE_STDIN_FILE="$payload" \
        AGENTGUARD_DENSE_STDOUT_FILE="$output" \
        AGENTGUARD_EXPECT_HIGH_FD="$high_fd_enabled" \
        "$dense_classifier" --json -- 'printf ok' \
        <"$payload" >"$output" 2>"$error"
    fi
  )
  rc=$?
  set -e

  if [[ $highest -lt 253 && $rc -eq 0 ]]; then
    _pass "$kind: dense descriptors through $highest safely succeed when available"
    _assert_not_contains "$kind: private fds 253 and 254 do not leak" \
      "private fd" "$(cat "$error")"
