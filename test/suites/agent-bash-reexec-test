_run_xtracefd_entry() {
  local kind="$1" mode="$2" control_fd="$3"
  local output="$TEST_TMPDIR/xtracefd-$kind-$mode-$control_fd.output"
  local error="$TEST_TMPDIR/xtracefd-$kind-$mode-$control_fd.error"
  local input="$TEST_TMPDIR/xtracefd-$kind-$mode-$control_fd.input"
  local capture="$TEST_TMPDIR/xtracefd-$kind-$mode-$control_fd.capture"
  local rc
  printf '%s\n' first second >"$input"
  set +e
  (
    if [[ $control_fd == 8 ]]; then
      exec 8<>"$input"
      IFS= read -r initial <&8 || exit 90
      [[ $initial == first ]] || exit 91
    fi
    if [[ $kind == hook ]]; then
      if [[ $mode == dirty ]]; then
        printf '%s' '{"tool_input":{"command":"true"}}' |
          env -i HOME="$HOME" PATH="$PATH" BASH_XTRACEFD="$control_fd" \
            AGENTGUARD_CONTROL_PROBE="$control_probe" \
            AGENTGUARD_CONTROL_FD="$control_fd" \
            AGENTGUARD_CONTROL_CAPTURE="$capture" \
            'BASH_FUNC_agentguard_xtracefd%%=() { :; }' \
            "$control_hook" >"$output" 2>"$error"
      else
        printf '%s' '{"tool_input":{"command":"true"}}' |
          env -i HOME="$HOME" PATH="$PATH" BASH_XTRACEFD="$control_fd" \
            AGENTGUARD_CONTROL_PROBE="$control_probe" \
            AGENTGUARD_CONTROL_FD="$control_fd" \
            AGENTGUARD_CONTROL_CAPTURE="$capture" \
            "$control_hook" >"$output" 2>"$error"
      fi
    elif [[ $mode == dirty ]]; then
      env -i HOME="$HOME" PATH="$PATH" BASH_XTRACEFD="$control_fd" \
        AGENTGUARD_CONTROL_PROBE="$control_probe" \
        AGENTGUARD_CONTROL_FD="$control_fd" \
        AGENTGUARD_CONTROL_CAPTURE="$capture" \
        'BASH_FUNC_agentguard_xtracefd%%=() { :; }' \
        "$control_classifier" --json -- 'printf ok' >"$output" 2>"$error"
    else
      env -i HOME="$HOME" PATH="$PATH" BASH_XTRACEFD="$control_fd" \
        AGENTGUARD_CONTROL_PROBE="$control_probe" \
        AGENTGUARD_CONTROL_FD="$control_fd" \
        AGENTGUARD_CONTROL_CAPTURE="$capture" \
        "$control_classifier" --json -- 'printf ok' >"$output" 2>"$error"
    fi
  )
  rc=$?
  set -e
  _assert_eq "$kind $mode BASH_XTRACEFD=$control_fd: entry succeeds" "0" "$rc"
  _assert_not_contains "$kind $mode BASH_XTRACEFD=$control_fd: control state is removed" \
    "BASH_XTRACEFD leaked" "$(cat "$error")"
  if [[ $control_fd == 2 ]]; then
    _assert_contains "$kind $mode BASH_XTRACEFD=2: stderr remains writable" \
      "agentguard-stderr-preserved" "$(cat "$error")"
  else
    _assert_eq "$kind $mode BASH_XTRACEFD=8: shared read offset is preserved" \
      "second" "$(cat "$capture" 2>/dev/null)"
    _assert_contains "$kind $mode BASH_XTRACEFD=8: read-write mode is preserved" \
      "third" "$(cat "$input")"
  fi
}

