          AGENTGUARD_DESCRIPTOR_READ_CAPTURE="$read_capture" \
          AGENTGUARD_DESCRIPTOR_STDIN_FILE="$payload" \
          AGENTGUARD_DESCRIPTOR_STDOUT_FILE="$output" \
          "$descriptor_hook" <"$payload" >"$output" 2>"$error"
      fi
    elif [ "$mode" = dirty ]; then
      # shellcheck disable=SC2094 # Env values name, but do not access, redirected files.
