#!/usr/bin/env bash
# agent-bash-reexec-test - modern-Bash launcher failure behavior.

# shellcheck disable=SC1090,SC1091 # dynamic helper path resolved at runtime.
AGENTGUARD_TEST_HELPERS="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/agent-hook-helpers.sh"
. "$AGENTGUARD_TEST_HELPERS"

CLASSIFY_COMMAND="$BIN_DIR/agentguard-classify-command"
REAL_BASH=$(type -P bash)

_assert_eq "pre-bash: fixed bootstrap is privileged Bash" "#!/bin/bash -p" \
  "$(head -n 1 "$PRE_BASH")"
_assert_eq "classifier: fixed bootstrap is privileged Bash" "#!/bin/bash -p" \
  "$(head -n 1 "$CLASSIFY_COMMAND")"

echo ""
echo "=== modern Bash launcher ==="

modern_home="$TEST_TMPDIR/modern-bash-home"
mkdir -p "$modern_home/.local/bin"
launcher_log="$TEST_TMPDIR/modern-bash-launcher.log"
cat >"$modern_home/.local/bin/bash" <<EOF
#!/bin/sh
printf '%s\n' invoked >>"$launcher_log"
exec "$REAL_BASH" "\$@"
EOF
chmod +x "$modern_home/.local/bin/bash"

_install_candidate_fixture() {
  local install="$1" candidate="$2" entry generated
  _install_hook_fixture \
    "$install" agent-hook-pre-bash agentguard-classify-command
  for entry in agent-hook-pre-bash agentguard-classify-command; do
    generated="$install/bin/$entry.generated"
    sed "s#/opt/homebrew/bin/bash#$candidate#" \
      "$install/bin/$entry" >"$generated"
    command cat "$generated" >"$install/bin/$entry"
    rm -f "$generated"
  done
}

modern_install="$TEST_TMPDIR/modern-bash-install"
_install_candidate_fixture "$modern_install" "$modern_home/.local/bin/bash"
modern_hook="$modern_install/bin/agent-hook-pre-bash"
modern_classifier="$modern_install/bin/agentguard-classify-command"

set +e
hook_output=$(printf '%s' '{"tool_input":{"command":"rm -rf /"}}' |
  "$modern_hook" 2>"$TEST_TMPDIR/hook-modern.err")
hook_rc=$?
classifier_output=$("$modern_classifier" --json -- 'printf ok' \
  2>"$TEST_TMPDIR/classifier-modern.err")
classifier_rc=$?
set -e
_assert_eq "pre-bash: re-exec preserves and blocks a dangerous payload" "2" "$hook_rc"
_assert_contains "pre-bash: re-exec reports the preserved dangerous payload" "BLOCKED" \
  "$(cat "$TEST_TMPDIR/hook-modern.err")"
_assert_eq "pre-bash: blocked re-exec emits protocol JSON" "{}" "$hook_output"
_assert_eq "classifier: re-execs a validated modern Bash" "0" "$classifier_rc"
_assert_eq "classifier: modern Bash preserves classification" "printf" \
  "$(jq -r '.commands[0].basename' <<<"$classifier_output")"
_assert_contains "launcher: configured modern Bash was invoked" "invoked" "$(cat "$launcher_log")"

# Explicit interpreter invocation bypasses the privileged shebang and is outside
# the supported security boundary. An otherwise ordinary, detectable invocation
# should still stop before reading stdin or loading application code, but that is
# best-effort hygiene rather than a security guarantee: BASH_ENV can change or
# forge behavior before the first script instruction, which no script can undo
# or reliably detect. Direct executable invocation is the supported entry path.
explicit_install="$TEST_TMPDIR/explicit-install"
explicit_hook="$explicit_install/bin/agent-hook-pre-bash"
explicit_classifier="$explicit_install/bin/agentguard-classify-command"
explicit_application_capture="$TEST_TMPDIR/explicit-application.capture"
explicit_startup_capture="$TEST_TMPDIR/explicit-startup.capture"
explicit_input="$TEST_TMPDIR/explicit.input"
_install_hook_fixture "$explicit_install" agent-hook-pre-bash agentguard-classify-command
cat >"$explicit_install/bin/agent-hook-pre-bash-work" <<'EOF'
: >"$AGENTGUARD_APPLICATION_CAPTURE"
EOF
explicit_module="$explicit_install/lib/agentguard/hook-command-classifier.sh"
mv "$explicit_module" "$explicit_module.original"
{
  # shellcheck disable=SC2016 # The fixture module expands the capture path.
  printf '%s\n' ': >"$AGENTGUARD_APPLICATION_CAPTURE"'
  cat "$explicit_module.original"
} >"$explicit_module"
printf '%s\n' '{"tool_input":{"command":"true"}}' >"$explicit_input"

set +e
(
  exec 9<"$explicit_input"
  AGENTGUARD_APPLICATION_CAPTURE="$explicit_application_capture" \
    /bin/bash --noprofile --norc "$explicit_hook" \
    >"$TEST_TMPDIR/hook-explicit.out" 2>"$TEST_TMPDIR/hook-explicit.err" <&9
  printf '%s' "$?" >"$TEST_TMPDIR/hook-explicit.rc"
  IFS= read -r explicit_remaining <&9 || :
  printf '%s\n' "$explicit_remaining" >"$TEST_TMPDIR/hook-explicit.remaining"
)
AGENTGUARD_APPLICATION_CAPTURE="$explicit_application_capture" \
  /bin/bash --noprofile --norc "$explicit_classifier" --json -- 'printf ok' \
  >"$TEST_TMPDIR/classifier-explicit.out" 2>"$TEST_TMPDIR/classifier-explicit.err"
explicit_classifier_rc=$?
cat >"$TEST_TMPDIR/hostile-bash-env" <<'EOF'
: >"$AGENTGUARD_STARTUP_CAPTURE"
EOF
BASH_ENV="$TEST_TMPDIR/hostile-bash-env" \
  AGENTGUARD_APPLICATION_CAPTURE="$explicit_application_capture" \
  AGENTGUARD_STARTUP_CAPTURE="$explicit_startup_capture" \
  /bin/bash --noprofile --norc "$explicit_hook" \
  >"$TEST_TMPDIR/hook-explicit-startup.out" \
  2>"$TEST_TMPDIR/hook-explicit-startup.err" </dev/null
explicit_startup_rc=$?
set -e

_assert_eq "pre-bash: detectable explicit Bash is best-effort rejected" "2" \
  "$(cat "$TEST_TMPDIR/hook-explicit.rc")"
_assert_contains "pre-bash: best-effort explicit rejection names direct execution" \
  "execute this file directly" "$(cat "$TEST_TMPDIR/hook-explicit.err")"
_assert_eq "pre-bash: detectable explicit Bash emits no allow protocol" "" \
  "$(cat "$TEST_TMPDIR/hook-explicit.out")"
_assert_eq "pre-bash: detectable explicit Bash leaves stdin unread" \
  "$(cat "$explicit_input")" \
  "$(cat "$TEST_TMPDIR/hook-explicit.remaining")"
_assert_file_missing \
  "pre-bash: detectable explicit Bash does not load application code" \
  "$explicit_application_capture"
_assert_eq "classifier: detectable explicit Bash is best-effort rejected" "2" \
  "$explicit_classifier_rc"
_assert_contains "classifier: best-effort explicit rejection names direct execution" \
  "execute this file directly" "$(cat "$TEST_TMPDIR/classifier-explicit.err")"
_assert_eq "classifier: detectable explicit Bash emits no classification" "" \
  "$(cat "$TEST_TMPDIR/classifier-explicit.out")"
_assert_file_missing \
  "classifier: detectable explicit Bash does not load application code" \
  "$explicit_application_capture"
_assert_file_exists \
  "explicit Bash: BASH_ENV runs outside the script's security boundary" \
  "$explicit_startup_capture"
_assert_eq "explicit Bash: ordinary startup leaves invocation detectable" "2" \
  "$explicit_startup_rc"

rm -f "$explicit_application_capture"
set +e
printf '%s' '{"tool_input":{"command":"true"}}' |
  env 'BASH_FUNC_exit%%=() { return 0; }' \
    AGENTGUARD_APPLICATION_CAPTURE="$explicit_application_capture" \
    /bin/bash --noprofile --norc "$explicit_hook" \
    >"$TEST_TMPDIR/hook-explicit-imported-exit.out" \
    2>"$TEST_TMPDIR/hook-explicit-imported-exit.err"
explicit_imported_exit_rc=$?
set -e
_assert_eq "pre-bash: detectable explicit Bash ignores an imported exit" "2" \
  "$explicit_imported_exit_rc"
_assert_file_missing \
  "pre-bash: detectable imported exit does not reach application code" \
  "$explicit_application_capture"

rm -f "$explicit_application_capture"
set +e
printf '%s' '{"tool_input":{"command":"true"}}' |
  env 'BASH_FUNC_unset%%=() { return 0; }' \
    'BASH_FUNC_exec%%=() { return 0; }' \
    AGENTGUARD_APPLICATION_CAPTURE="$explicit_application_capture" \
    /bin/bash --noprofile --norc "$explicit_hook" \
    >"$TEST_TMPDIR/hook-explicit-imported-control.out" \
    2>"$TEST_TMPDIR/hook-explicit-imported-control.err"
explicit_imported_control_hook_rc=$?
set -e
_assert_eq "pre-bash: imported control functions cannot continue explicit Bash" "2" \
  "$explicit_imported_control_hook_rc"
_assert_eq "pre-bash: imported control functions emit no allow protocol" "" \
  "$(cat "$TEST_TMPDIR/hook-explicit-imported-control.out")"
_assert_file_missing \
  "pre-bash: imported control functions do not reach application code" \
  "$explicit_application_capture"

rm -f "$explicit_application_capture"
set +e
env 'BASH_FUNC_unset%%=() { return 0; }' \
  'BASH_FUNC_exec%%=() { return 0; }' \
  AGENTGUARD_APPLICATION_CAPTURE="$explicit_application_capture" \
  /bin/bash --noprofile --norc "$explicit_classifier" --json -- 'printf ok' \
  >"$TEST_TMPDIR/classifier-explicit-imported-control.out" \
  2>"$TEST_TMPDIR/classifier-explicit-imported-control.err"
explicit_imported_control_classifier_rc=$?
set -e
_assert_eq "classifier: imported control functions cannot continue explicit Bash" "2" \
  "$explicit_imported_control_classifier_rc"
_assert_eq "classifier: imported control functions emit no classification" "" \
  "$(cat "$TEST_TMPDIR/classifier-explicit-imported-control.out")"
_assert_file_missing \
  "classifier: imported control functions do not reach application code" \
  "$explicit_application_capture"

rm -f "$explicit_startup_capture"
AGENTGUARD_APPLICATION_CAPTURE="$explicit_application_capture" \
  AGENTGUARD_STARTUP_CAPTURE="$explicit_startup_capture" \
  BASH_ENV="$TEST_TMPDIR/hostile-bash-env" \
  "$explicit_classifier" --json -- 'printf ok' \
  >"$TEST_TMPDIR/classifier-direct.out" 2>"$TEST_TMPDIR/classifier-direct.err"
_assert_file_missing "direct execution: privileged shebang ignores BASH_ENV" \
  "$explicit_startup_capture"
_assert_file_exists "direct execution: application code still runs" \
  "$explicit_application_capture"

# Privileged Bash suppresses function import but retains the raw BASH_FUNC_*
# environment entries. A candidate implemented as a shell wrapper must not
# import them before it reaches the validated Bash binary.
wrapper_function_capture="$TEST_TMPDIR/wrapper-function.capture"
: >"$wrapper_function_capture"
# shellcheck disable=SC2016 # Expanded only if a candidate imports the fixture.
imported_printf='() { /bin/echo imported >>"$AGENTGUARD_FUNCTION_CAPTURE"; /usr/bin/printf "$@"; }'
set +e
printf '%s' '{"tool_input":{"command":"true"}}' |
  env "BASH_FUNC_printf%%=$imported_printf" \
    AGENTGUARD_FUNCTION_CAPTURE="$wrapper_function_capture" \
    "$modern_hook" \
    >"$TEST_TMPDIR/hook-wrapper-function.out" \
    2>"$TEST_TMPDIR/hook-wrapper-function.err"
wrapper_function_hook_rc=$?
env "BASH_FUNC_printf%%=$imported_printf" \
  AGENTGUARD_FUNCTION_CAPTURE="$wrapper_function_capture" \
  "$modern_classifier" --json -- 'printf ok' \
  >"$TEST_TMPDIR/classifier-wrapper-function.out" \
  2>"$TEST_TMPDIR/classifier-wrapper-function.err"
wrapper_function_classifier_rc=$?
set -e
if [ "$wrapper_function_hook_rc" -ne 0 ]; then
  sed 's/^/    hook stderr: /' "$TEST_TMPDIR/hook-wrapper-function.err" >&2
fi
if [ "$wrapper_function_classifier_rc" -ne 0 ]; then
  sed 's/^/    classifier stderr: /' "$TEST_TMPDIR/classifier-wrapper-function.err" >&2
fi
_assert_eq "pre-bash: a candidate wrapper starts without imported functions" \
  "0" "$wrapper_function_hook_rc"
_assert_eq "classifier: a candidate wrapper starts without imported functions" \
  "0" "$wrapper_function_classifier_rc"
_assert_eq "launcher: candidate wrappers never execute imported functions" \
  "" "$(cat "$wrapper_function_capture")"

# A fixed candidate can be a wrapper around a valid Bash. If that wrapper closes
# the launcher's private descriptors, it must be rejected before its handshake
# can downgrade the hook's explicit blocking status.
closing_candidate="$TEST_TMPDIR/fd-closing-bash"
cat >"$closing_candidate" <<EOF
#!/bin/bash
fd=3
while [ "\$fd" -le 254 ]; do
  eval "exec \$fd>&-" 2>/dev/null || :
  eval "exec \$fd<&-" 2>/dev/null || :
  fd=\$((fd + 1))
done
exec "$REAL_BASH" "\$@"
EOF
chmod +x "$closing_candidate"
closing_install="$TEST_TMPDIR/fd-closing-install"
_install_hook_fixture \
  "$closing_install" agent-hook-pre-bash agentguard-classify-command
for closing_entry in agent-hook-pre-bash agentguard-classify-command; do
  closing_path="$closing_install/bin/$closing_entry"
  sed "s#/opt/homebrew/bin/bash /usr/local/bin/bash /bin/bash /usr/bin/bash#$closing_candidate $closing_candidate $closing_candidate $closing_candidate#" \
    "$closing_path" >"$closing_path.tmp"
  command cat "$closing_path.tmp" >"$closing_path"
  rm -f "$closing_path.tmp"
done

for closing_mode in clean dirty; do
  closing_env=(env -i HOME="$HOME" PATH="$PATH")
  if [[ $closing_mode == dirty ]]; then
    closing_env+=('BASH_FUNC_agentguard_fd_closer%%=() { :; }')
  fi
  set +e
  printf '%s' '{"tool_input":{"command":"true"}}' |
    _with_timeout 5 "${closing_env[@]}" \
      "$closing_install/bin/agent-hook-pre-bash" \
      >"$TEST_TMPDIR/hook-fd-closing-$closing_mode.out" \
      2>"$TEST_TMPDIR/hook-fd-closing-$closing_mode.err"
  closing_hook_rc=$?
  _with_timeout 5 "${closing_env[@]}" \
    "$closing_install/bin/agentguard-classify-command" --json -- 'printf ok' \
    >"$TEST_TMPDIR/classifier-fd-closing-$closing_mode.out" \
    2>"$TEST_TMPDIR/classifier-fd-closing-$closing_mode.err"
  closing_classifier_rc=$?
  set -e
  _assert_eq "pre-bash: $closing_mode fd-closing candidate fails closed" \
    "2" "$closing_hook_rc"
  _assert_contains "pre-bash: $closing_mode fd-closing failure is actionable" \
    "Bash 4 or newer" "$(cat "$TEST_TMPDIR/hook-fd-closing-$closing_mode.err")"
  _assert_eq "pre-bash: $closing_mode fd-closing candidate emits no allow response" \
    "" "$(cat "$TEST_TMPDIR/hook-fd-closing-$closing_mode.out")"
  _assert_eq "classifier: $closing_mode fd-closing candidate fails closed" \
    "2" "$closing_classifier_rc"
  _assert_contains "classifier: $closing_mode fd-closing failure is actionable" \
    "Bash 4 or newer" \
    "$(cat "$TEST_TMPDIR/classifier-fd-closing-$closing_mode.err")"
  _assert_eq "classifier: $closing_mode fd-closing candidate emits no classification" \
    "" "$(cat "$TEST_TMPDIR/classifier-fd-closing-$closing_mode.out")"
done

invalid_home="$TEST_TMPDIR/invalid-bash-home"
mkdir -p "$invalid_home/.local/bin"
invalid_log="$TEST_TMPDIR/invalid-bash-launcher.log"
cat >"$invalid_home/.local/bin/bash" <<EOF
#!/bin/sh
for arg; do
  if [ "\$arg" = -c ]; then
    printf '%s\n' probe >>"$invalid_log"
    exit 1
  fi
done
printf '%s\n' executed >>"$invalid_log"
exit 79
EOF
chmod +x "$invalid_home/.local/bin/bash"
invalid_install="$TEST_TMPDIR/invalid-bash-install"
_install_candidate_fixture "$invalid_install" "$invalid_home/.local/bin/bash"
invalid_hook="$invalid_install/bin/agent-hook-pre-bash"
invalid_classifier="$invalid_install/bin/agentguard-classify-command"

set +e
printf '%s' '{"tool_input":{}}' |
  "$invalid_hook" \
    >"$TEST_TMPDIR/hook-invalid.out" 2>"$TEST_TMPDIR/hook-invalid.err"
invalid_hook_rc=$?
"$invalid_classifier" --json -- 'printf ok' \
  >"$TEST_TMPDIR/classifier-invalid.out" 2>"$TEST_TMPDIR/classifier-invalid.err"
invalid_classifier_rc=$?
set -e
_assert_contains "launcher: unusable candidate is probed" "probe" "$(cat "$invalid_log")"
_assert_not_contains "launcher: unusable candidate is never re-executed" "executed" "$(cat "$invalid_log")"
# A platform-level fallback may exist after the injected invalid candidate. Either
# successful fallback or an explicit usage failure is acceptable here.
case "$invalid_hook_rc:$invalid_classifier_rc" in
  0:0 | 2:2) _pass "launcher: both entry points handle an unusable candidate consistently" ;;
  *) _fail "launcher: both entry points handle an unusable candidate consistently" ;;
esac

false_home="$TEST_TMPDIR/false-bash-home"
mkdir -p "$false_home/.local/bin"
ln -s /bin/true "$false_home/.local/bin/bash"
false_install="$TEST_TMPDIR/false-bash-install"
_install_candidate_fixture "$false_install" "$false_home/.local/bin/bash"
false_hook="$false_install/bin/agent-hook-pre-bash"
false_classifier="$false_install/bin/agentguard-classify-command"

set +e
printf '%s' '{"tool_input":{"command":"rm -rf /"}}' |
  "$false_hook" \
    >"$TEST_TMPDIR/hook-false.out" 2>"$TEST_TMPDIR/hook-false.err"
false_hook_rc=$?
"$false_classifier" --json -- 'rm -rf /' \
  >"$TEST_TMPDIR/classifier-false.out" 2>"$TEST_TMPDIR/classifier-false.err"
false_classifier_rc=$?
set -e
_assert_eq "pre-bash: a success-only executable cannot bypass the guard" "2" "$false_hook_rc"
case "$false_classifier_rc" in
  2)
    _pass "classifier: a success-only executable fails closed without a fallback"
    ;;
  0)
    if [ -s "$TEST_TMPDIR/classifier-false.out" ] &&
      jq -e '.commands[0].basename == "rm"' "$TEST_TMPDIR/classifier-false.out" >/dev/null; then
      _pass "classifier: a success-only executable is skipped for a valid fallback"
    else
      _fail "classifier: a success-only executable is skipped for a valid fallback"
    fi
    ;;
  *)
    _fail "classifier: a success-only executable has a valid outcome"
    ;;
esac

hostile_path="$TEST_TMPDIR/hostile-path"
mkdir -p "$hostile_path"
ln -s /bin/true "$hostile_path/bash"
set +e
printf '%s' '{"tool_input":{"command":"rm -rf /"}}' |
  PATH="$hostile_path:/usr/bin:/bin" "$PRE_BASH" \
    >"$TEST_TMPDIR/hook-hostile-path.out" 2>"$TEST_TMPDIR/hook-hostile-path.err"
hostile_path_hook_rc=$?
PATH="$hostile_path:/usr/bin:/bin" "$CLASSIFY_COMMAND" --json -- 'printf ok' \
  >"$TEST_TMPDIR/classifier-hostile-path.out" 2>"$TEST_TMPDIR/classifier-hostile-path.err"
hostile_path_classifier_rc=$?
set -e
_assert_eq "pre-bash: the bootstrap interpreter ignores a hostile PATH bash" \
  "2" "$hostile_path_hook_rc"
_assert_eq "classifier: the bootstrap interpreter ignores a hostile PATH bash" \
  "0" "$hostile_path_classifier_rc"
_assert_eq "classifier: hostile PATH still preserves classification" "printf" \
  "$(jq -r '.commands[0].basename' "$TEST_TMPDIR/classifier-hostile-path.out")"

# Candidate discovery is a filesystem trust boundary. Caller-selected HOME and
# PATH values must not be able to nominate an executable that can forge the
# public handshake without ever entering application code.
for hostile_candidate_source in home path; do
  hostile_candidate_root="$TEST_TMPDIR/hostile-$hostile_candidate_source-candidate"
  hostile_candidate_bin="$hostile_candidate_root/bin"
  hostile_candidate_marker="$hostile_candidate_root/invoked"
  mkdir -p "$hostile_candidate_bin" "$hostile_candidate_root/.local/bin"
  cat >"$hostile_candidate_root/fake-bash" <<EOF
#!/bin/sh
: >"$hostile_candidate_marker"
printf '%s\n' agentguard-modern-bash-v2
exit 0
EOF
  chmod +x "$hostile_candidate_root/fake-bash"
  if [[ $hostile_candidate_source == home ]]; then
    ln -s "$hostile_candidate_root/fake-bash" \
      "$hostile_candidate_root/.local/bin/bash"
    hostile_candidate_home="$hostile_candidate_root"
    hostile_candidate_path="$PATH"
  else
    ln -s "$hostile_candidate_root/fake-bash" "$hostile_candidate_bin/bash"
    hostile_candidate_home=relative-home
    hostile_candidate_path="$hostile_candidate_bin:$PATH"
  fi

  rm -f "$hostile_candidate_marker"
  set +e
  printf '%s' '{"tool_input":{"command":"rm -rf /"}}' |
    env HOME="$hostile_candidate_home" PATH="$hostile_candidate_path" \
      "$PRE_BASH" >"$hostile_candidate_root/hook.out" \
      2>"$hostile_candidate_root/hook.err"
  hostile_candidate_hook_rc=$?
  env HOME="$hostile_candidate_home" PATH="$hostile_candidate_path" \
    "$CLASSIFY_COMMAND" --json -- 'rm -rf /' \
    >"$hostile_candidate_root/classifier.out" \
    2>"$hostile_candidate_root/classifier.err"
  hostile_candidate_classifier_rc=$?
  set -e

  _assert_eq "pre-bash: hostile $hostile_candidate_source candidate cannot allow" \
    "2" "$hostile_candidate_hook_rc"
  _assert_contains "pre-bash: hostile $hostile_candidate_source candidate still blocks" \
    "BLOCKED" "$(cat "$hostile_candidate_root/hook.err")"
  _assert_eq "classifier: hostile $hostile_candidate_source candidate completes" \
    "0" "$hostile_candidate_classifier_rc"
  _assert_eq "classifier: hostile $hostile_candidate_source candidate preserves classification" \
    "rm" "$(jq -r '.commands[0].basename' \
      "$hostile_candidate_root/classifier.out" 2>/dev/null)"
  _assert_file_missing "launcher: hostile $hostile_candidate_source candidate is never invoked" \
    "$hostile_candidate_marker"
done

startup_env="$TEST_TMPDIR/hostile-bash-env"
startup_capture="$TEST_TMPDIR/hostile-bash-env.capture"
cat >"$startup_env" <<'EOF'
cat >>"$AGENTGUARD_STARTUP_CAPTURE"
EOF
: >"$startup_capture"
set +e
printf '%s' '{"tool_input":{"command":"rm -rf /"}}' |
  BASH_ENV="$startup_env" ENV="$startup_env" AGENTGUARD_STARTUP_CAPTURE="$startup_capture" \
    "$PRE_BASH" \
    >"$TEST_TMPDIR/hook-startup-env.out" 2>"$TEST_TMPDIR/hook-startup-env.err"
startup_env_hook_rc=$?
printf '%s' 'rm -rf /' |
  BASH_ENV="$startup_env" ENV="$startup_env" AGENTGUARD_STARTUP_CAPTURE="$startup_capture" \
    "$CLASSIFY_COMMAND" \
    >"$TEST_TMPDIR/classifier-startup-env.out" 2>"$TEST_TMPDIR/classifier-startup-env.err"
startup_env_classifier_rc=$?
set -e
_assert_eq "pre-bash: startup files cannot consume the hook payload" "2" "$startup_env_hook_rc"
_assert_eq "classifier: startup files cannot consume stdin" "0" "$startup_env_classifier_rc"
_assert_eq "classifier: sanitized startup preserves stdin classification" "rm" \
  "$(jq -r '.commands[0].basename' "$TEST_TMPDIR/classifier-startup-env.out")"
_assert_eq "launcher: sanitized startup files never execute" "" "$(cat "$startup_capture")"

# A candidate that is replaced while it validates must not be looked up again
# before script entry. The already-running, validated Bash owns the handoff.
for swap_kind in hook classifier; do
  swap_home="$TEST_TMPDIR/swap-$swap_kind-home"
  swap_wrapper="$TEST_TMPDIR/swap-$swap_kind-wrapper"
  swap_candidate="$swap_home/.local/bin/bash"
  mkdir -p "$swap_home/.local/bin"
  cat >"$swap_wrapper" <<EOF
#!/bin/sh
rm -f "$swap_candidate"
ln -s /bin/true "$swap_candidate"
exec "$REAL_BASH" "\$@"
EOF
  chmod +x "$swap_wrapper"
  ln -s "$swap_wrapper" "$swap_candidate"
  swap_install="$TEST_TMPDIR/swap-$swap_kind-install"
  _install_candidate_fixture "$swap_install" "$swap_candidate"
  set +e
  if [ "$swap_kind" = hook ]; then
    printf '%s' '{"tool_input":{"command":"rm -rf /"}}' |
      _with_timeout 5 "$swap_install/bin/agent-hook-pre-bash" \
        >"$TEST_TMPDIR/swap-hook.out" 2>"$TEST_TMPDIR/swap-hook.err"
    swap_rc=$?
  else
    _with_timeout 5 "$swap_install/bin/agentguard-classify-command" \
      --json -- 'rm -rf /' \
